@page
@model Automator.Web.Pages.Account.LoginModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In – Automator</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
</head>
<body class="bg-dark d-flex align-items-center justify-content-center" style="min-height: 100vh;">
    <div class="card shadow-lg border-0" style="width: 380px;">
        <div class="card-body p-4">
            <div class="text-center mb-4">
                <i class="bi bi-lightning-charge-fill text-warning" style="font-size: 2.5rem;"></i>
                <h4 class="mt-2 fw-bold mb-0">Automator</h4>
                <p class="text-muted small mt-1">IaaS Script Automation</p>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger py-2 small">
                    <i class="bi bi-exclamation-triangle-fill me-1"></i>@Model.ErrorMessage
                </div>
            }

            <form method="post">
                <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
                <div class="mb-3">
                    <label asp-for="Username" class="form-label fw-semibold">Username</label>
                    <input asp-for="Username" class="form-control" autofocus autocomplete="username"
                           placeholder="Enter your username" />
                </div>
                <div class="mb-3">
                    <label asp-for="Password" class="form-label fw-semibold">Password</label>
                    <input asp-for="Password" type="password" class="form-control"
                           autocomplete="current-password" placeholder="Enter your password" />
                </div>
                <div class="mb-4 form-check">
                    <input asp-for="RememberMe" class="form-check-input" type="checkbox" />
                    <label asp-for="RememberMe" class="form-check-label text-muted small">Keep me signed in</label>
                </div>
                <button type="submit" class="btn btn-primary w-100 fw-semibold">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
                </button>
            </form>
        </div>
        <div class="card-footer text-center text-muted py-2" style="font-size: 0.75rem;">
            Default admin: <strong>admin</strong> / configured in appsettings.json
        </div>
    </div>
</body>
</html>
