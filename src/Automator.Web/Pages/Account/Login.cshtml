@page
@model Automator.Web.Pages.Account.LoginModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In – Automator</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; }

        body {
            margin: 0;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #212529;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        }

        .card {
            width: 380px;
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 8px 40px rgba(0, 0, 0, 0.45);
            overflow: hidden;
        }

        .card-body {
            padding: 2rem;
        }

        .card-footer {
            padding: 0.75rem 2rem;
            background: #f8f9fa;
            border-top: 1px solid #e9ecef;
            text-align: center;
            font-size: 0.75rem;
            color: #6c757d;
        }

        .logo {
            text-align: center;
            margin-bottom: 1.75rem;
        }

        .logo-bolt {
            font-size: 2.5rem;
            line-height: 1;
        }

        .logo h4 {
            margin: 0.5rem 0 0;
            font-weight: 700;
            font-size: 1.5rem;
            color: #212529;
        }

        .logo p {
            margin: 0.25rem 0 0;
            color: #6c757d;
            font-size: 0.875rem;
        }

        .error-box {
            background: #fde8e8;
            color: #9b2335;
            border: 1px solid #f5c6cb;
            border-radius: 6px;
            padding: 0.625rem 0.875rem;
            margin-bottom: 1.25rem;
            font-size: 0.875rem;
        }

        .form-group {
            margin-bottom: 1rem;
        }

        label {
            display: block;
            margin-bottom: 0.375rem;
            font-weight: 600;
            font-size: 0.875rem;
            color: #212529;
        }

        input[type="text"],
        input[type="password"] {
            width: 100%;
            padding: 0.5625rem 0.75rem;
            border: 1px solid #ced4da;
            border-radius: 6px;
            font-size: 0.9rem;
            color: #212529;
            background: #fff;
            outline: none;
            transition: border-color 0.15s, box-shadow 0.15s;
        }

        input[type="text"]:focus,
        input[type="password"]:focus {
            border-color: #1976d2;
            box-shadow: 0 0 0 3px rgba(25, 118, 210, 0.18);
        }

        .remember {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin-bottom: 1.25rem;
            font-size: 0.875rem;
            color: #6c757d;
        }

        .remember label {
            margin: 0;
            font-weight: normal;
            color: #6c757d;
            cursor: pointer;
        }

        .btn-submit {
            width: 100%;
            padding: 0.6875rem 1rem;
            background: #1976d2;
            color: #fff;
            border: none;
            border-radius: 6px;
            font-size: 0.9375rem;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.15s;
            letter-spacing: 0.01em;
        }

        .btn-submit:hover {
            background: #1565c0;
        }

        .btn-submit:active {
            background: #0d47a1;
        }
    </style>
</head>
<body>
    <div class="card">
        <div class="card-body">
            <div class="logo">
                <div class="logo-bolt">⚡</div>
                <h4>Automator</h4>
                <p>IaaS Script Automation</p>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="error-box">⚠ @Model.ErrorMessage</div>
            }

            <form method="post">
                <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
                <div class="form-group">
                    <label asp-for="Username">Username</label>
                    <input asp-for="Username" type="text" autofocus autocomplete="username"
                           placeholder="Enter your username" />
                </div>
                <div class="form-group">
                    <label asp-for="Password">Password</label>
                    <input asp-for="Password" type="password"
                           autocomplete="current-password" placeholder="Enter your password" />
                </div>
                <div class="remember">
                    <input asp-for="RememberMe" type="checkbox" id="rm" />
                    <label for="rm">Keep me signed in</label>
                </div>
                <button type="submit" class="btn-submit">Sign In</button>
            </form>
        </div>
        <div class="card-footer">
            Default admin: <strong>admin</strong> / configured in appsettings.json
        </div>
    </div>
</body>
</html>
