{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=automator.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Automator": {
    "MaxConcurrentExecutions": 5,
    "ExecutionTimeoutSeconds": 300
  }
}
