{
  "DatabaseProvider": "Sqlite",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=automator.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "DetailedErrors": true,
  "DefaultAdmin": {
    "Username": "admin",
    "Email": "admin@localhost",
    "Password": "Admin1234!"
  },
  "DefaultOperator": {
    "Username": "operator",
    "Email": "operator@localhost",
    "Password": "Operator1234!"
  },
  "DefaultViewer": {
    "Username": "viewer",
    "Email": "viewer@localhost",
    "Password": "Viewer1234!"
  },
  "Automator": {
    "MaxConcurrentExecutions": 5,
    "ExecutionTimeoutSeconds": 300
  }
}
