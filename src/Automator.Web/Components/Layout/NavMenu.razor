@inject NavigationManager Nav
@implements IDisposable

<div class="app-sidebar">
    <div class="app-sidebar-logo">
        <div style="display: flex; align-items: center; gap: 0.5rem;">
            <MudIcon Icon="@Icons.Material.Filled.Bolt" Color="Color.Warning" />
            <MudText Typo="Typo.h6" Style="color: white; font-weight: 700; margin: 0; line-height: 1.2;">Automator</MudText>
        </div>
    </div>

    <MudNavMenu>
        <MudNavLink Href="" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
        <MudNavLink Href="scripts" Icon="@Icons.Material.Filled.LibraryBooks">Script Library</MudNavLink>
        <MudNavLink Href="runner" Icon="@Icons.Material.Filled.PlayCircle">Run Script</MudNavLink>
        <MudNavLink Href="history" Icon="@Icons.Material.Filled.History">History</MudNavLink>
        <MudNavLink Href="jobs" Icon="@Icons.Material.Filled.CalendarToday">Scheduled Jobs</MudNavLink>
        <AuthorizeView Roles="Admin">
            <MudNavLink Href="settings" Icon="@Icons.Material.Filled.Settings">Settings</MudNavLink>
        </AuthorizeView>
    </MudNavMenu>

    <div class="app-sidebar-footer">
        <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.45);">
            Bash · PowerShell · Python · Ansible
        </MudText>
    </div>
</div>

@code {
    protected override void OnInitialized() =>
        Nav.LocationChanged += OnLocationChanged;

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e) =>
        InvokeAsync(StateHasChanged);

    public void Dispose() =>
        Nav.LocationChanged -= OnLocationChanged;
}
