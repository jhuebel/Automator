@inherits LayoutComponentBase
@inject HelpDrawerState HelpState
@implements IDisposable

<div style="display: flex; height: 100vh; overflow: hidden;">
    <NavMenu />
    <div style="flex: 1; display: flex; flex-direction: column; min-width: 0;">
        <div class="app-header">
            <MudIcon Icon="@Icons.Material.Filled.Bolt" Color="Color.Warning" />
            <MudText Typo="Typo.h6" Style="color: white; font-weight: 700; margin: 0;">Automator</MudText>
            <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.55); margin-left: 4px;">IaaS Script Automation</MudText>
            <div style="margin-left: auto;">
                <AppHeader />
            </div>
        </div>
        <main class="app-content">
            @Body
        </main>
    </div>
</div>
<HelpDrawer />
<MudProviders />

@code {
    protected override void OnInitialized() =>
        HelpState.OnChange += OnHelpStateChanged;

    private void OnHelpStateChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() =>
        HelpState.OnChange -= OnHelpStateChanged;
}
