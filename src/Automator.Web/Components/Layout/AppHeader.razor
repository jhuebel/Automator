@inject HelpDrawerState HelpState

<AuthorizeView>
    <Authorized>
        <div style="display: flex; align-items: center; gap: 0.5rem;">
            <AuthorizeView Roles="Admin" Context="_a">
                <MudChip T="string" Color="Color.Error" Size="Size.Small" Class="ma-0">Admin</MudChip>
            </AuthorizeView>
            <AuthorizeView Roles="Developer" Context="_d">
                <MudChip T="string" Color="Color.Tertiary" Size="Size.Small" Class="ma-0">Developer</MudChip>
            </AuthorizeView>
            <AuthorizeView Roles="Operator" Context="_o">
                <MudChip T="string" Color="Color.Primary" Size="Size.Small" Class="ma-0">Operator</MudChip>
            </AuthorizeView>
            <AuthorizeView Roles="Viewer" Context="_v">
                <MudChip T="string" Color="Color.Default" Size="Size.Small" Class="ma-0">Viewer</MudChip>
            </AuthorizeView>
            <MudIconButton Icon="@Icons.Material.Outlined.HelpOutline"
                           Size="Size.Small"
                           OnClick="HelpState.Toggle"
                           Style="color: rgba(255,255,255,0.7);"
                           title="Help" />
            <MudMenu Label="@context.User.Identity?.Name"
                     EndIcon="@Icons.Material.Filled.ArrowDropDown"
                     AnchorOrigin="Origin.BottomRight"
                     TransformOrigin="Origin.TopRight"
                     Class="user-header-menu">
                <MudMenuItem Href="/profile" Icon="@Icons.Material.Filled.ManageAccounts">My Account</MudMenuItem>
                <MudDivider />
                <MudMenuItem Href="/account/logout" Icon="@Icons.Material.Filled.Logout" IconColor="Color.Error">
                    <MudText Color="Color.Error">Sign Out</MudText>
                </MudMenuItem>
            </MudMenu>
        </div>
    </Authorized>
</AuthorizeView>
