@page "/runner"
@page "/runner/{ScriptId:guid}"
@attribute [Authorize(Roles = "Admin,Developer,Operator")]
@inject IScriptRunnerService ScriptService
@implements IDisposable

<PageTitle>Run Script - Automator</PageTitle>

<MudText Typo="Typo.h5" Class="mb-3">Run Script</MudText>

<PageHelp>
    Scripts run as the OS user hosting this application and inherit its environment variables.
    Output streams line-by-line in real time. Use <strong>Cancel</strong> to terminate early.
    All runs — successful or not — are saved to <MudLink Href="/history">History</MudLink>.
    Exit code <code>0</code> = success; any other value = failure.
</PageHelp>

<MudGrid Spacing="3">
    <MudItem xs="12" md="4">
        <MudCard Elevation="1">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Select Script</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent Style="padding: 0; max-height: 400px; overflow-y: auto;">
                <MudList T="ScriptDefinition" Dense="true" Padding="false"
                         SelectedValue="SelectedScript" SelectedValueChanged="SelectScript">
                    @foreach (var script in ScriptService.Scripts.OrderBy(s => s.Name))
                    {
                        <MudListItem T="ScriptDefinition" Value="@script"
                                     Style="@(SelectedScript?.Id == script.Id ? "background: var(--mud-palette-primary-lighten); font-weight: 600;" : "")">
                            <div style="display: flex; align-items: center; gap: 0.5rem;">
                                <MudChip T="string" Color="@script.Language.ToColor()" Size="Size.Small" Style="min-width: 80px; justify-content: center;">@script.Language.ToDisplayName()</MudChip>
                                <MudText Typo="Typo.body2">@script.Name</MudText>
                            </div>
                        </MudListItem>
                        <MudDivider />
                    }
                    @if (!ScriptService.Scripts.Any())
                    {
                        <MudListItem T="ScriptDefinition">
                            <MudText Color="Color.Secondary">No scripts. <MudLink Href="/scripts">Add one</MudLink>.</MudText>
                        </MudListItem>
                    }
                </MudList>
            </MudCardContent>
        </MudCard>

        @if (SelectedScript is not null)
        {
            <MudCard Elevation="1" Class="mt-3">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Script Details</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <div style="margin-bottom: 0.5rem;">
                        <MudChip T="string" Color="@SelectedScript.Language.ToColor()" Size="Size.Small" Class="mb-1">@SelectedScript.Language.ToDisplayName()</MudChip>
                        <MudText Typo="Typo.body1" Style="font-weight: 600;">@SelectedScript.Name</MudText>
                        @if (!string.IsNullOrEmpty(SelectedScript.Description))
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">@SelectedScript.Description</MudText>
                        }
                    </div>
                    @foreach (var tag in SelectedScript.Tags)
                    {
                        <MudChip T="string" Color="Color.Default" Size="Size.Small">@tag</MudChip>
                    }
                </MudCardContent>
                <MudCardActions>
                    @if (!IsRunning)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Success" FullWidth="true"
                                   StartIcon="@Icons.Material.Filled.PlayArrow" OnClick="RunSelected">Run</MudButton>
                    }
                    else
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Error" FullWidth="true"
                                   StartIcon="@Icons.Material.Filled.Stop" OnClick="CancelRun">Cancel</MudButton>
                    }
                </MudCardActions>
            </MudCard>
        }
    </MudItem>

    <MudItem xs="12" md="8">
        <MudCard Elevation="1" Class="h-100">
            <MudCardHeader>
                <CardHeaderContent>
                    <div style="display: flex; align-items: center; justify-content: space-between;">
                        <div style="display: flex; align-items: center; gap: 0.5rem;">
                            <MudIcon Icon="@Icons.Material.Filled.Terminal" />
                            <MudText Typo="Typo.h6">Output</MudText>
                            @if (IsRunning)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Warning" />
                            }
                            else if (CurrentResult is not null)
                            {
                                @if (CurrentResult.IsSuccess)
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Size="Size.Small" />
                                }
                            }
                        </div>
                        @if (CurrentResult is not null)
                        {
                            <div style="display: flex; align-items: center; gap: 0.75rem;">
                                @if (CurrentResult.Duration.HasValue)
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@CurrentResult.Duration.Value.TotalSeconds.ToString("F2")s</MudText>
                                }
                                @if (CurrentResult.ExitCode.HasValue)
                                {
                                    <MudChip T="string" Color="@(CurrentResult.IsSuccess ? Color.Success : Color.Error)" Size="Size.Small">
                                        exit @CurrentResult.ExitCode
                                    </MudChip>
                                }
                                <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Small"
                                               Color="Color.Default" OnClick="ClearOutput" />
                            </div>
                        }
                    </div>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent Style="padding: 0; flex: 1;">
                <pre id="output-container" class="output-terminal" style="border-radius: 0 0 4px 4px;">@if (OutputLines.Count == 0)
{<span style="color: #6b7280;">Select a script and click Run to see output here.</span>}
@foreach (var line in OutputLines)
{<span class="@(line.IsError ? "output-error" : "")">@(line.Text + "\n")</span>}</pre>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    [Parameter] public Guid? ScriptId { get; set; }
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private string _username = string.Empty;
    private ScriptDefinition? SelectedScript { get; set; }
    private ScriptExecutionResult? CurrentResult { get; set; }
    private List<OutputLine> OutputLines { get; } = [];
    private bool IsRunning { get; set; }
    private CancellationTokenSource? _cts;

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is not null)
            _username = (await AuthState).User.Identity?.Name ?? string.Empty;
    }

    protected override void OnParametersSet()
    {
        if (ScriptId.HasValue)
            SelectedScript = ScriptService.GetScript(ScriptId.Value);
    }

    private void SelectScript(ScriptDefinition? script)
    {
        SelectedScript = script;
        ClearOutput();
    }

    private async Task RunSelected()
    {
        if (SelectedScript is null || IsRunning) return;

        OutputLines.Clear();
        IsRunning = true;
        _cts = new CancellationTokenSource();

        var progress = new Progress<OutputLine>(line =>
        {
            OutputLines.Add(line);
            InvokeAsync(StateHasChanged);
        });

        try
        {
            CurrentResult = await ScriptService.ExecuteScriptAsync(
                SelectedScript.Id, progress, _cts.Token, _username);
        }
        finally
        {
            IsRunning = false;
            _cts?.Dispose();
            _cts = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void CancelRun() => _cts?.Cancel();

    private void ClearOutput()
    {
        OutputLines.Clear();
        CurrentResult = null;
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
    }
}
