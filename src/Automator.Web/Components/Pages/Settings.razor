@page "/settings"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@inject IDbContextFactory<AutomatorDbContext> DbFactory
@inject IAuditLogService AuditService
@inject NavigationManager Nav

<PageTitle>Settings - Automator</PageTitle>

<style>
    .nav-tabs button.nav-link.active { color: var(--bs-body-color, #212529) !important; }
</style>

<h4 class="mb-3">Settings</h4>

<ul class="nav nav-tabs mb-4">
    <li class="nav-item">
        <button type="button" class="nav-link @(ActiveTab == "application" ? "active" : "")" @onclick='() => ActiveTab = "application"'>
            <i class="bi bi-sliders me-1"></i>Application
        </button>
    </li>
    <li class="nav-item">
        <button type="button" class="nav-link @(ActiveTab == "users" ? "active" : "")" @onclick='() => ActiveTab = "users"'>
            <i class="bi bi-people-fill me-1"></i>Users
        </button>
    </li>
    <li class="nav-item">
        <button type="button" class="nav-link @(ActiveTab == "status" ? "active" : "")" @onclick='() => ActiveTab = "status"'>
            <i class="bi bi-heart-pulse me-1"></i>System Status
        </button>
    </li>
    <li class="nav-item">
        <button type="button" class="nav-link @(ActiveTab == "audit" ? "active" : "")" @onclick='() => { ActiveTab = "audit"; LoadAuditLogs(); }'>
            <i class="bi bi-journal-text me-1"></i>Audit Logs
        </button>
    </li>
</ul>

@if (ActiveTab == "application")
{
    <PageHelp>
        Tune runtime behaviour. Timeout and history changes take effect immediately; concurrency changes require a restart.
    </PageHelp>
    <div class="row">
        <div class="col-lg-5 col-md-7">
            @if (AppSettings is not null)
            {
                <div class="card">
                    <div class="card-header fw-semibold">
                        <i class="bi bi-sliders me-2"></i>Application Settings
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Execution Timeout
                                <HelpIcon Text="Maximum seconds a script may run before it is automatically cancelled. Default: 300 (5 minutes)." />
                            </label>
                            <div class="input-group" style="max-width: 200px;">
                                <input class="form-control" type="number" @bind="AppSettings.ExecutionTimeoutSeconds" min="10" max="3600" />
                                <span class="input-group-text">s</span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Max Concurrent Executions
                                <HelpIcon Text="How many scripts may run at the same time. Requires a restart to take effect. Default: 5." />
                            </label>
                            <input class="form-control" type="number" @bind="AppSettings.MaxConcurrentExecutions" min="1" max="20" style="max-width: 100px;" />
                            <div class="form-text">Requires restart to take effect.</div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                History Retention
                                <HelpIcon Text="Number of recent execution records shown in History. Older records stay in the database. Default: 1000." />
                            </label>
                            <div class="input-group" style="max-width: 200px;">
                                <input class="form-control" type="number" @bind="AppSettings.MaxHistoryRecords" min="10" max="10000" />
                                <span class="input-group-text">records</span>
                            </div>
                        </div>

                        <button class="btn btn-primary" @onclick="SaveAppSettingsAsync" disabled="@IsSavingAppSettings">
                            <i class="bi bi-floppy me-1"></i>Save
                        </button>
                        @if (!string.IsNullOrEmpty(AppSettingsMessage))
                        {
                            <div class="alert @(AppSettingsSuccess ? "alert-success" : "alert-danger") py-2 small mt-2 mb-0">@AppSettingsMessage</div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
}
else if (ActiveTab == "users")
{
    <UserManagementPanel />
}
else if (ActiveTab == "status")
{
    <SystemStatusPanel />
}
else if (ActiveTab == "audit")
{
    <div class="d-flex align-items-center justify-content-between mb-3">
        <div class="d-flex align-items-center gap-2">
            <select class="form-select form-select-sm" style="width: auto;" @bind="AuditFilter" @bind:after="FilterLogs">
                <option value="">All actions</option>
                <option value="Login">Login</option>
                <option value="Script">Scripts</option>
                <option value="Job">Jobs</option>
                <option value="User">Users</option>
                <option value="Settings">Settings</option>
            </select>
        </div>
        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="LoadAuditLogs">
            <i class="bi bi-arrow-clockwise me-1"></i>Refresh
        </button>
    </div>

    @if (AuditLogs is null)
    {
        <div class="d-flex align-items-center gap-2 text-muted">
            <span class="spinner-border spinner-border-sm"></span> Loading logs...
        </div>
    }
    else if (!AuditLogs.Any())
    {
        <div class="text-muted">No audit log entries found.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover table-sm align-middle">
                <thead class="table-dark">
                    <tr>
                        <th class="text-nowrap">Timestamp</th>
                        <th>User</th>
                        <th>Action</th>
                        <th>Resource</th>
                        <th>Details</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in AuditLogs)
                    {
                        <tr>
                            <td class="text-nowrap text-muted small">@log.Timestamp.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                            <td class="small fw-semibold">@(log.Username ?? "—")</td>
                            <td>
                                <span class="badge @ActionBadgeClass(log.Action)">@log.Action</span>
                            </td>
                            <td class="small">@(log.Resource ?? "—")</td>
                            <td class="small text-muted">@(log.Details ?? "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="text-muted small">Showing @AuditLogs.Count most recent entries</div>
    }
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private string _username = string.Empty;
    private string ActiveTab { get; set; } = "application";

    private AppSetting? AppSettings { get; set; }
    private bool IsSavingAppSettings { get; set; }
    private string AppSettingsMessage { get; set; } = string.Empty;
    private bool AppSettingsSuccess { get; set; }

    private IReadOnlyList<AuditLog>? AuditLogs { get; set; }
    private string AuditFilter { get; set; } = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is not null)
            _username = (await AuthState).User.Identity?.Name ?? string.Empty;

        var uri = new Uri(Nav.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        ActiveTab = query["tab"] ?? "application";

        using var db = DbFactory.CreateDbContext();
        AppSettings = db.Settings.Find(1) ?? new AppSetting { Id = 1 };

        if (ActiveTab == "audit")
            LoadAuditLogs();
    }

    private void LoadAuditLogs()
    {
        var all = AuditService.GetRecentLogs(200);
        AuditLogs = string.IsNullOrEmpty(AuditFilter)
            ? all
            : all.Where(l => l.Action.StartsWith(AuditFilter, StringComparison.OrdinalIgnoreCase)).ToList();
    }

    private void FilterLogs() => LoadAuditLogs();

    private async Task SaveAppSettingsAsync()
    {
        if (AppSettings is null) return;
        AppSettings.ExecutionTimeoutSeconds = Math.Clamp(AppSettings.ExecutionTimeoutSeconds, 10, 3600);
        AppSettings.MaxConcurrentExecutions = Math.Clamp(AppSettings.MaxConcurrentExecutions, 1, 20);
        AppSettings.MaxHistoryRecords = Math.Clamp(AppSettings.MaxHistoryRecords, 10, 10000);

        IsSavingAppSettings = true;
        try
        {
            using var db = DbFactory.CreateDbContext();
            if (db.Settings.Find(1) is null)
                db.Settings.Add(AppSettings);
            else
                db.Settings.Update(AppSettings);
            await db.SaveChangesAsync();
            AppSettingsSuccess = true;
            AppSettingsMessage = "Settings saved.";
            _ = AuditService.LogAsync("Settings.Updated", null,
                $"timeout={AppSettings.ExecutionTimeoutSeconds}s, concurrency={AppSettings.MaxConcurrentExecutions}, history={AppSettings.MaxHistoryRecords}",
                _username);
        }
        catch (Exception ex)
        {
            AppSettingsSuccess = false;
            AppSettingsMessage = $"Save failed: {ex.Message}";
        }
        finally { IsSavingAppSettings = false; }
    }

    private static string ActionBadgeClass(string action) => action switch
    {
        _ when action.StartsWith("Login.Failed") => "bg-danger",
        _ when action.StartsWith("Login") => "bg-success",
        _ when action.StartsWith("Script.Executed") => "bg-primary",
        _ when action.StartsWith("Script") => "bg-info text-dark",
        _ when action.StartsWith("Job") => "bg-warning text-dark",
        _ when action.StartsWith("User") => "bg-secondary",
        _ when action.StartsWith("Settings") => "bg-dark",
        _ => "bg-secondary"
    };
}
