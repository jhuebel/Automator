@page "/settings"
@attribute [Authorize(Roles = "Admin")]
@inject IDbContextFactory<AutomatorDbContext> DbFactory
@inject IAuditLogService AuditService
@inject NavigationManager Nav

<PageTitle>Settings - Automator</PageTitle>

<MudText Typo="Typo.h5" Class="mb-3">Settings</MudText>

<MudTabs Elevation="1" Rounded="true" ApplyEffectsToContainer="true" Class="mb-4"
         @bind-ActivePanelIndex="_activePanelIndex" @bind-ActivePanelIndex:after="OnTabChanged">
    <MudTabPanel Text="Application" Icon="@Icons.Material.Filled.Tune">
        <div style="padding: 1.5rem 0;">
            <PageHelp>
                Tune runtime behaviour. Timeout and history changes take effect immediately; concurrency changes require a restart.
            </PageHelp>
            <div style="max-width: 500px;">
                @if (AppSettings is not null)
                {
                    <MudCard Elevation="1">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <div style="display: flex; align-items: center; gap: 0.5rem;">
                                    <MudIcon Icon="@Icons.Material.Filled.Tune" Size="Size.Small" />
                                    <MudText Typo="Typo.h6">Application Settings</MudText>
                                </div>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudNumericField T="int" @bind-Value="AppSettings.ExecutionTimeoutSeconds"
                                            Label="Execution Timeout (seconds)"
                                            HelperText="Max seconds a script may run before auto-cancel. Default: 300."
                                            Min="10" Max="3600" Variant="Variant.Outlined" Margin="Margin.Dense"
                                            Class="mb-3" Adornment="Adornment.End" AdornmentText="s" />
                            <MudNumericField T="int" @bind-Value="AppSettings.MaxConcurrentExecutions"
                                            Label="Max Concurrent Executions"
                                            HelperText="How many scripts may run simultaneously. Requires restart. Default: 5."
                                            Min="1" Max="20" Variant="Variant.Outlined" Margin="Margin.Dense"
                                            Class="mb-3" Style="max-width: 200px;" />
                            <MudNumericField T="int" @bind-Value="AppSettings.MaxHistoryRecords"
                                            Label="History Retention (records)"
                                            HelperText="Number of recent executions shown in History. Default: 1000."
                                            Min="10" Max="10000" Variant="Variant.Outlined" Margin="Margin.Dense"
                                            Class="mb-2" Adornment="Adornment.End" AdornmentText="records" />
                            @if (!string.IsNullOrEmpty(AppSettingsMessage))
                            {
                                <MudAlert Severity="@(AppSettingsSuccess ? Severity.Success : Severity.Error)" Dense="true" Class="mt-2">@AppSettingsMessage</MudAlert>
                            }
                        </MudCardContent>
                        <MudCardActions>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save"
                                       OnClick="SaveAppSettingsAsync" Disabled="@IsSavingAppSettings">Save</MudButton>
                        </MudCardActions>
                    </MudCard>
                }
            </div>
        </div>
    </MudTabPanel>

    <MudTabPanel Text="Users" Icon="@Icons.Material.Filled.Group">
        <div style="padding: 1.5rem 0;">
            <UserManagementPanel />
        </div>
    </MudTabPanel>

    <MudTabPanel Text="System Status" Icon="@Icons.Material.Filled.Monitor">
        <div style="padding: 1.5rem 0;">
            <SystemStatusPanel />
        </div>
    </MudTabPanel>

    <MudTabPanel Text="Audit Logs" Icon="@Icons.Material.Filled.ListAlt">
        <div style="padding: 1.5rem 0;">
            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem; flex-wrap: wrap; gap: 0.5rem;">
                <MudSelect T="string" @bind-Value="AuditFilter" @bind-Value:after="FilterLogs"
                           Label="Filter by action" Variant="Variant.Outlined" Margin="Margin.Dense"
                           Style="max-width: 200px;" AnchorOrigin="Origin.BottomLeft">
                    @foreach (var opt in AuditFilterOptions)
                    {
                        <MudSelectItem T="string" Value="@opt.Value">@opt.Label</MudSelectItem>
                    }
                </MudSelect>
                <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Refresh"
                           Size="Size.Small" OnClick="LoadAuditLogs">Refresh</MudButton>
            </div>

            @if (AuditLogs is null)
            {
                <div style="display: flex; align-items: center; gap: 0.5rem;">
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                    <MudText Color="Color.Secondary">Loading logs...</MudText>
                </div>
            }
            else if (!AuditLogs.Any())
            {
                <MudText Color="Color.Secondary">No audit log entries found.</MudText>
            }
            else
            {
                <MudPaper Elevation="1" Class="overflow-auto">
                    <MudSimpleTable Hover="true" Dense="true">
                        <thead>
                            <tr>
                                <th style="white-space: nowrap;">Timestamp</th>
                                <th>User</th>
                                <th>Action</th>
                                <th>Resource</th>
                                <th>Details</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in AuditLogs)
                            {
                                <tr>
                                    <td style="white-space: nowrap; font-size: 0.8125rem; color: var(--mud-palette-text-secondary);">@log.Timestamp.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                                    <td style="font-size: 0.8125rem; font-weight: 600;">@(log.Username ?? "—")</td>
                                    <td>
                                        <MudChip T="string" Color="@ActionColor(log.Action)" Size="Size.Small">@log.Action</MudChip>
                                    </td>
                                    <td style="font-size: 0.8125rem;">@(log.Resource ?? "—")</td>
                                    <td style="font-size: 0.8125rem; color: var(--mud-palette-text-secondary);">@(log.Details ?? "—")</td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                </MudPaper>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">Showing @AuditLogs.Count most recent entries</MudText>
            }
        </div>
    </MudTabPanel>
</MudTabs>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private string _username = string.Empty;
    private int _activePanelIndex;

    private AppSetting? AppSettings { get; set; }
    private bool IsSavingAppSettings { get; set; }
    private string AppSettingsMessage { get; set; } = string.Empty;
    private bool AppSettingsSuccess { get; set; }

    private IReadOnlyList<AuditLog>? AuditLogs { get; set; }
    private string AuditFilter { get; set; } = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is not null)
            _username = (await AuthState).User.Identity?.Name ?? string.Empty;

        var uri = new Uri(Nav.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        var tabName = query["tab"] ?? "application";
        _activePanelIndex = tabName switch
        {
            "users" => 1,
            "status" => 2,
            "audit" => 3,
            _ => 0
        };

        using var db = DbFactory.CreateDbContext();
        AppSettings = db.Settings.Find(1) ?? new AppSetting { Id = 1 };

        if (_activePanelIndex == 3)
            LoadAuditLogs();
    }

    private void OnTabChanged()
    {
        if (_activePanelIndex == 3)
            LoadAuditLogs();
    }

    private static readonly (string Value, string Label)[] AuditFilterOptions =
    [
        ("", "All actions"),
        ("Login", "Login"),
        ("Script", "Scripts"),
        ("Job", "Jobs"),
        ("User", "Users"),
        ("Settings", "Settings"),
    ];

    private void LoadAuditLogs()
    {
        var all = AuditService.GetRecentLogs(200);
        AuditLogs = string.IsNullOrEmpty(AuditFilter)
            ? all
            : all.Where(l => l.Action.StartsWith(AuditFilter, StringComparison.OrdinalIgnoreCase)).ToList();
    }

    private void FilterLogs() => LoadAuditLogs();

    private async Task SaveAppSettingsAsync()
    {
        if (AppSettings is null) return;
        AppSettings.ExecutionTimeoutSeconds = Math.Clamp(AppSettings.ExecutionTimeoutSeconds, 10, 3600);
        AppSettings.MaxConcurrentExecutions = Math.Clamp(AppSettings.MaxConcurrentExecutions, 1, 20);
        AppSettings.MaxHistoryRecords = Math.Clamp(AppSettings.MaxHistoryRecords, 10, 10000);

        IsSavingAppSettings = true;
        try
        {
            using var db = DbFactory.CreateDbContext();
            if (db.Settings.Find(1) is null)
                db.Settings.Add(AppSettings);
            else
                db.Settings.Update(AppSettings);
            await db.SaveChangesAsync();
            AppSettingsSuccess = true;
            AppSettingsMessage = "Settings saved.";
            _ = AuditService.LogAsync("Settings.Updated", null,
                $"timeout={AppSettings.ExecutionTimeoutSeconds}s, concurrency={AppSettings.MaxConcurrentExecutions}, history={AppSettings.MaxHistoryRecords}",
                _username);
        }
        catch (Exception ex)
        {
            AppSettingsSuccess = false;
            AppSettingsMessage = $"Save failed: {ex.Message}";
        }
        finally { IsSavingAppSettings = false; }
    }

    private static Color ActionColor(string action) => action switch
    {
        _ when action.StartsWith("Login.Failed") => Color.Error,
        _ when action.StartsWith("Login") => Color.Success,
        _ when action.StartsWith("Script.Executed") => Color.Primary,
        _ when action.StartsWith("Script") => Color.Info,
        _ when action.StartsWith("Job") => Color.Warning,
        _ when action.StartsWith("User") => Color.Default,
        _ when action.StartsWith("Settings") => Color.Dark,
        _ => Color.Default
    };
}
