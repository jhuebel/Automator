@page "/history"
@attribute [Authorize]
@inject IScriptRunnerService ScriptService

<PageTitle>Execution History - Automator</PageTitle>

<MudText Typo="Typo.h5" Class="mb-3">Execution History</MudText>

<PageHelp>
    Every script execution is recorded here — whether run manually or by a scheduled job. Click any row to expand
    the full terminal output. Status icons: <strong>green check</strong> = success (exit code 0),
    <strong>red X</strong> = failure (non-zero exit code), <strong>spinner</strong> = currently running.
    <strong>Duration</strong> is wall-clock time; <strong>Exit Code 0</strong> means success.
</PageHelp>

@if (!ScriptService.ExecutionHistory.Any())
{
    <MudText Color="Color.Secondary">No executions yet. <MudLink Href="/runner">Run a script</MudLink> to get started.</MudText>
}
else
{
    <MudPaper Elevation="1" Class="overflow-auto">
        <MudSimpleTable Hover="true" Dense="true">
            <thead>
                <tr>
                    <th style="width: 48px;"></th>
                    <th>Script</th>
                    <th>Language</th>
                    <th>Started</th>
                    <th>Duration</th>
                    <th>Exit Code</th>
                    <th>Output</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var run in ScriptService.ExecutionHistory)
                {
                    <tr style="cursor: pointer;" @onclick="() => ToggleExpand(run.ExecutionId)">
                        <td>
                            @if (run.IsRunning)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Warning" />
                            }
                            else if (run.IsSuccess)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" Title="Success" />
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Size="Size.Small" Title="@($"Failed (exit {run.ExitCode})")" />
                            }
                        </td>
                        <td style="font-weight: 600;">@run.ScriptName</td>
                        <td><MudChip T="string" Color="@run.Language.ToColor()" Size="Size.Small">@run.Language.ToDisplayName()</MudChip></td>
                        <td style="white-space: nowrap;">@run.StartedAt.ToLocalTime().ToString("g")</td>
                        <td style="white-space: nowrap;">
                            @if (run.Duration.HasValue)
                            {
                                @($"{run.Duration.Value.TotalSeconds:F2}s")
                            }
                            else
                            {
                                <MudText Color="Color.Secondary" Typo="Typo.body2">—</MudText>
                            }
                        </td>
                        <td>
                            @if (run.ExitCode.HasValue)
                            {
                                <MudChip T="string" Color="@(run.IsSuccess ? Color.Success : Color.Error)" Size="Size.Small">@run.ExitCode</MudChip>
                            }
                        </td>
                        <td>
                            <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Default"
                                       EndIcon="@(_expanded.Contains(run.ExecutionId) ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                       OnClick="() => ToggleExpand(run.ExecutionId)">
                                @run.Output.Count lines
                            </MudButton>
                        </td>
                    </tr>
                    @if (_expanded.Contains(run.ExecutionId))
                    {
                        <tr>
                            <td colspan="7" style="padding: 0;">
                                <pre class="output-terminal" style="border-radius: 0; min-height: unset; max-height: 300px;">@foreach (var line in run.Output)
{<span class="@(line.IsError ? "output-error" : "")">@(line.Text + "\n")</span>}</pre>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </MudSimpleTable>
    </MudPaper>
}

@code {
    private readonly HashSet<Guid> _expanded = [];

    private void ToggleExpand(Guid id)
    {
        if (!_expanded.Add(id))
            _expanded.Remove(id);
    }
}
