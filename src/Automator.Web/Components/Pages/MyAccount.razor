@page "/profile"
@attribute [Authorize]
@inject UserManager<ApplicationUser> UserManager

<PageTitle>My Account - Automator</PageTitle>

<MudText Typo="Typo.h5" Class="mb-3">My Account</MudText>

<PageHelp>
    Change your email address or password. These changes apply to your own account only.
</PageHelp>

<MudGrid Spacing="4">
    <MudItem xs="12" md="6" lg="5">
        <MudCard Elevation="1">
            <MudCardHeader>
                <CardHeaderContent>
                    <div style="display: flex; align-items: center; gap: 0.5rem;">
                        <MudIcon Icon="@Icons.Material.Filled.Email" />
                        <MudText Typo="Typo.h6">Email Address</MudText>
                    </div>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                    Signed in as <strong>@CurrentUsername</strong>
                </MudText>
                <MudTextField @bind-Value="NewEmail" Label="Email address" InputType="InputType.Email"
                              Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2" />
                @if (!string.IsNullOrEmpty(EmailMessage))
                {
                    <MudAlert Severity="@(EmailSuccess ? Severity.Success : Severity.Error)" Dense="true" Class="mt-2">@EmailMessage</MudAlert>
                }
            </MudCardContent>
            <MudCardActions>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ChangeEmailAsync"
                           Disabled="@IsSavingEmail">Update Email</MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>

    <MudItem xs="12" md="6" lg="5">
        <MudCard Elevation="1">
            <MudCardHeader>
                <CardHeaderContent>
                    <div style="display: flex; align-items: center; gap: 0.5rem;">
                        <MudIcon Icon="@Icons.Material.Filled.Key" />
                        <MudText Typo="Typo.h6">Change Password</MudText>
                    </div>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudTextField @bind-Value="CurrentPassword" Label="Current password" InputType="InputType.Password"
                              Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2" />
                <MudTextField @bind-Value="NewPassword" Label="New password (min 8 chars)" InputType="InputType.Password"
                              Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2" />
                <MudTextField @bind-Value="ConfirmPassword" Label="Confirm new password" InputType="InputType.Password"
                              Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2" />
                @if (!string.IsNullOrEmpty(PasswordMessage))
                {
                    <MudAlert Severity="@(PasswordSuccess ? Severity.Success : Severity.Error)" Dense="true" Class="mt-2">@PasswordMessage</MudAlert>
                }
            </MudCardContent>
            <MudCardActions>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ChangePasswordAsync"
                           Disabled="@IsSavingPassword">Change Password</MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private string? CurrentUserId { get; set; }
    private string CurrentUsername { get; set; } = string.Empty;

    private string NewEmail { get; set; } = string.Empty;
    private bool IsSavingEmail { get; set; }
    private string EmailMessage { get; set; } = string.Empty;
    private bool EmailSuccess { get; set; }

    private string CurrentPassword { get; set; } = string.Empty;
    private string NewPassword { get; set; } = string.Empty;
    private string ConfirmPassword { get; set; } = string.Empty;
    private bool IsSavingPassword { get; set; }
    private string PasswordMessage { get; set; } = string.Empty;
    private bool PasswordSuccess { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is not null)
        {
            var auth = await AuthState;
            CurrentUserId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            CurrentUsername = auth.User.Identity?.Name ?? string.Empty;
        }

        if (CurrentUserId is not null)
        {
            var user = await UserManager.FindByIdAsync(CurrentUserId);
            if (user is not null)
                NewEmail = user.Email ?? string.Empty;
        }
    }

    private async Task ChangeEmailAsync()
    {
        EmailMessage = string.Empty;
        if (string.IsNullOrWhiteSpace(NewEmail)) { EmailMessage = "Email cannot be empty."; return; }

        IsSavingEmail = true;
        try
        {
            var user = await UserManager.FindByIdAsync(CurrentUserId!);
            if (user is null) { EmailMessage = "User not found."; return; }

            user.Email = NewEmail.Trim();
            user.NormalizedEmail = NewEmail.Trim().ToUpperInvariant();
            user.EmailConfirmed = true;
            var result = await UserManager.UpdateAsync(user);

            EmailSuccess = result.Succeeded;
            EmailMessage = result.Succeeded
                ? "Email updated."
                : string.Join(" ", result.Errors.Select(e => e.Description));
        }
        finally { IsSavingEmail = false; }
    }

    private async Task ChangePasswordAsync()
    {
        PasswordMessage = string.Empty;
        if (string.IsNullOrWhiteSpace(CurrentPassword) || string.IsNullOrWhiteSpace(NewPassword))
        {
            PasswordMessage = "All password fields are required.";
            return;
        }
        if (NewPassword != ConfirmPassword)
        {
            PasswordMessage = "New passwords do not match.";
            return;
        }

        IsSavingPassword = true;
        try
        {
            var user = await UserManager.FindByIdAsync(CurrentUserId!);
            if (user is null) { PasswordMessage = "User not found."; return; }

            var result = await UserManager.ChangePasswordAsync(user, CurrentPassword, NewPassword);
            PasswordSuccess = result.Succeeded;
            PasswordMessage = result.Succeeded
                ? "Password changed successfully."
                : string.Join(" ", result.Errors.Select(e => e.Description));

            if (result.Succeeded)
                CurrentPassword = NewPassword = ConfirmPassword = string.Empty;
        }
        finally { IsSavingPassword = false; }
    }
}
