@page "/scripts/new"
@page "/scripts/edit/{Id:guid}"
@attribute [Authorize(Roles = "Admin,Developer")]
@inject IScriptRunnerService ScriptService
@inject IAuditLogService AuditService
@inject IClaudeService Claude
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>@(_isNew ? "New Script" : $"Edit: {_script.Name}") - Automator</PageTitle>

<div style="height: calc(100vh - 104px); display: flex; flex-direction: column; overflow: hidden;">

    @* Title bar *@
    <div style="flex-shrink: 0; display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem;">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Color="Color.Default"
                       OnClick="TryNavigateBack" title="Back to Script Library" />
        <MudText Typo="Typo.h5" Style="margin: 0;">@(_isNew ? "New Script" : $"Edit: {_script.Name}")</MudText>
    </div>

    @* Card *@
    <div style="flex: 1; min-height: 0; display: flex; flex-direction: column;
                background: var(--mud-palette-surface); border-radius: 4px;
                border-top: 4px solid var(--mud-palette-primary);
                box-shadow: 0 2px 4px -1px rgba(0,0,0,0.2), 0 4px 5px 0 rgba(0,0,0,0.14), 0 1px 10px 0 rgba(0,0,0,0.12);">

        @* General / Code / Variables tabs *@
        <MudTabs Elevation="0" Class="script-editor-tabs"
                 @bind-ActivePanelIndex="_activeTab">
            <MudTabPanel Text="General" Icon="@Icons.Material.Outlined.Info">
                <div style="padding: 16px; overflow-y: auto; height: 100%;">
                    <MudGrid Spacing="2">
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_script.Name" Label="Name" Variant="Variant.Outlined"
                                          Placeholder="Script name" Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudSelect T="ScriptLanguage" @bind-Value="_script.Language" Label="Language"
                                       Variant="Variant.Outlined" Margin="Margin.Dense">
                                @foreach (var lang in Enum.GetValues<ScriptLanguage>())
                                {
                                    <MudSelectItem T="ScriptLanguage" Value="@lang">@lang.ToDisplayName()</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudTextField @bind-Value="_tagsText" Label="Tags" Variant="Variant.Outlined" Margin="Margin.Dense"
                                          Placeholder="e.g. network, diagnostics"
                                          HelperText="Comma-separated keywords" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField @bind-Value="_script.Description" Label="Description"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder="Brief description" />
                        </MudItem>
                    </MudGrid>
                </div>
            </MudTabPanel>
            <MudTabPanel Text="Code" Icon="@Icons.Material.Outlined.Code">
                <div style="flex: 1; min-height: 0; padding: 8px 16px; display: flex; flex-direction: column;">
                    <div style="flex: 1; min-height: 0;">
                        <CodeEditor @ref="_editor" @bind-Value="_script.Content" Language="@_script.Language" Height="100%" />
                    </div>
                </div>
                @if (Claude.IsConfigured)
                {
                    <div style="flex-shrink: 0; padding: 0 16px 8px;">
                        <MudExpansionPanel Text="AI Assistant" Icon="@Icons.Material.Filled.AutoAwesome"
                                           Style="border: 1px solid var(--mud-palette-lines-inputs); border-radius:4px;">
                            <MudTabs @bind-ActivePanelIndex="_aiMode" Rounded="true" Border="true">
                                <MudTabPanel Text="Generate" Icon="@Icons.Material.Filled.Add">
                                    <div class="pa-3">
                                        <MudTextField @bind-Value="_aiPrompt" Label="Describe what the script should do"
                                                      Lines="2" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                    </div>
                                </MudTabPanel>
                                <MudTabPanel Text="Improve" Icon="@Icons.Material.Filled.Tune">
                                    <div class="pa-3">
                                        <MudTextField @bind-Value="_aiPrompt" Label="What should be improved or changed?"
                                                      Lines="2" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                    </div>
                                </MudTabPanel>
                                <MudTabPanel Text="Explain" Icon="@Icons.Material.Filled.HelpOutline">
                                    <div class="pa-3">
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">Click Explain to get a plain-language description of the current script.</MudText>
                                    </div>
                                </MudTabPanel>
                            </MudTabs>
                            <div style="display:flex; gap:0.5rem; margin-top:0.75rem; align-items:center;">
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="_aiRunning"
                                           StartIcon="@Icons.Material.Filled.AutoAwesome" OnClick="RunAi">
                                    @(_aiMode == 0 ? "Generate" : _aiMode == 1 ? "Improve" : "Explain")
                                </MudButton>
                                @if (_aiRunning)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Primary" />
                                    <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="CancelAi">Cancel</MudButton>
                                }
                            </div>
                            @if (_aiMode == 2 && !string.IsNullOrEmpty(_aiExplanation))
                            {
                                <MudPaper Class="mt-3 pa-3" Elevation="0" Style="background:var(--mud-palette-background-grey); border-radius:4px;">
                                    <MudText Typo="Typo.body2" Style="white-space: pre-wrap;">@_aiExplanation</MudText>
                                </MudPaper>
                            }
                            @if (!string.IsNullOrEmpty(_aiError))
                            {
                                <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2">@_aiError</MudAlert>
                            }
                        </MudExpansionPanel>
                    </div>
                }
            </MudTabPanel>
            <MudTabPanel Text="Variables" Icon="@Icons.Material.Filled.DataObject">
                <div style="padding: 16px; overflow-y: auto; height: 100%;">
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3" Style="display:block;">
                        Variables are passed as environment variables at runtime.
                        Access them in your script as <code>$NAME</code> (Bash), <code>$env:NAME</code> (PowerShell), or <code>os.environ['NAME']</code> (Python).
                    </MudText>
                    @foreach (var v in _script.Variables)
                    {
                        var variable = v;
                        <div style="display: flex; gap: 0.5rem; align-items: center; margin-bottom: 0.5rem; flex-wrap: wrap;">
                            <MudTextField @bind-Value="variable.Name" Label="Name" Variant="Variant.Outlined"
                                          Margin="Margin.Dense" Style="width: 130px; flex-shrink: 0;"
                                          Placeholder="VAR_NAME" />
                            <MudSelect T="ScriptVariableType" @bind-Value="variable.Type" Label="Type"
                                       Variant="Variant.Outlined" Margin="Margin.Dense" Style="width: 105px; flex-shrink: 0;">
                                @foreach (var t in Enum.GetValues<ScriptVariableType>())
                                {
                                    <MudSelectItem T="ScriptVariableType" Value="@t">@t</MudSelectItem>
                                }
                            </MudSelect>
                            <MudTextField @bind-Value="variable.DefaultValue" Label="Default" Variant="Variant.Outlined"
                                          Margin="Margin.Dense" Style="width: 140px; flex-shrink: 0;"
                                          Placeholder="@DefaultPlaceholder(variable.Type)" />
                            <MudTextField @bind-Value="variable.Description" Label="Description" Variant="Variant.Outlined"
                                          Margin="Margin.Dense" Style="flex: 1; min-width: 120px;" />
                            <MudCheckBox T="bool" @bind-Value="variable.Required" Label="Required" Size="Size.Small"
                                         Style="flex-shrink: 0; white-space: nowrap;" />
                            <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Small" Color="Color.Error"
                                           title="Remove variable" OnClick="() => _script.Variables.Remove(variable)" />
                        </div>
                    }
                    <MudButton StartIcon="@Icons.Material.Filled.Add" Size="Size.Small" Variant="Variant.Outlined"
                               OnClick="AddVariable">Add Variable</MudButton>
                </div>
            </MudTabPanel>
        </MudTabs>

        @* Validation error *@
        @if (!string.IsNullOrEmpty(_validationError))
        {
            <div style="flex-shrink: 0; padding: 0 16px 4px;">
                <MudAlert Severity="Severity.Error" Dense="true">@_validationError</MudAlert>
            </div>
        }

        @* Actions *@
        <div style="flex-shrink: 0; padding: 8px 16px; border-top: 1px solid var(--mud-palette-divider); display: flex; gap: 0.5rem;">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save"
                       OnClick="SaveScript">Save</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Default"
                       OnClick="TryNavigateBack">Cancel</MudButton>
        </div>

    </div>
</div>

@if (_showUnsavedDialog)
{
    <div style="position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 1000; display: flex; align-items: center; justify-content: center;">
        <MudCard Style="width: 360px;">
            <MudCardHeader>
                <CardHeaderContent><MudText Typo="Typo.h6">Unsaved Changes</MudText></CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                You have unsaved changes. Leave without saving?
            </MudCardContent>
            <MudCardActions>
                <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="DiscardAndNavigate">Discard changes</MudButton>
                <MudButton Variant="Variant.Outlined" OnClick="KeepEditing">Keep editing</MudButton>
            </MudCardActions>
        </MudCard>
    </div>
}

@code {
    [Parameter] public Guid? Id { get; set; }
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private string _username = string.Empty;
    private ScriptDefinition _script = new();
    private string _tagsText = string.Empty;
    private string _validationError = string.Empty;
    private bool _isNew;
    private bool _showUnsavedDialog;
    private CodeEditor? _editor;
    private string? _pendingNavUrl;
    private IDisposable? _locationChangingReg;
    private int _activeTab;  // 0=General, 1=Code, 2=Variables

    // Snapshot of values at load time — dirty when current state diverges
    private string _origName = string.Empty;
    private ScriptLanguage _origLanguage;
    private string _origDescription = string.Empty;
    private string _origContent = string.Empty;
    private string _origTagsText = string.Empty;

    private bool IsDirty =>
        _script.Name        != _origName        ||
        _script.Language    != _origLanguage    ||
        _script.Description != _origDescription ||
        _script.Content     != _origContent     ||
        _tagsText           != _origTagsText;

    private void CaptureSnapshot()
    {
        _origName        = _script.Name;
        _origLanguage    = _script.Language;
        _origDescription = _script.Description;
        _origContent     = _script.Content;
        _origTagsText    = _tagsText;
    }

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is not null)
            _username = (await AuthState).User.Identity?.Name ?? string.Empty;

        if (Id is null || Id == Guid.Empty)
        {
            _script = new ScriptDefinition { Id = Guid.Empty };
            _isNew = true;
        }
        else
        {
            var existing = ScriptService.Scripts.FirstOrDefault(s => s.Id == Id);
            if (existing is null)
            {
                Nav.NavigateTo("/scripts");
                return;
            }
            _script = existing.Clone();
            _tagsText = string.Join(", ", existing.Tags);
            _isNew = false;
        }

        CaptureSnapshot();
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
            _locationChangingReg = Nav.RegisterLocationChangingHandler(OnLocationChanging);
    }

    private async ValueTask OnLocationChanging(LocationChangingContext context)
    {
        if (!IsDirty) return;
        context.PreventNavigation();
        _pendingNavUrl = context.TargetLocation;
        _showUnsavedDialog = true;
        await InvokeAsync(StateHasChanged);
    }

    private void AddVariable() => _script.Variables.Add(new ScriptVariable());

    private static string DefaultPlaceholder(ScriptVariableType type) => type switch
    {
        ScriptVariableType.Number => "0",
        ScriptVariableType.Array  => "a, b, c",
        _                         => ""
    };

    private async Task TryNavigateBack()
    {
        // Flush the live CodeMirror value before comparing — closes the race between
        // rapid keystrokes (invokeMethodAsync) and the button click event.
        if (_editor is not null)
            _script.Content = await _editor.GetCurrentValueAsync();

        if (IsDirty)
        {
            _pendingNavUrl = "/scripts";
            _showUnsavedDialog = true;
        }
        else
        {
            Nav.NavigateTo("/scripts");
        }
    }

    private void DiscardAndNavigate()
    {
        CaptureSnapshot(); // makes IsDirty false so the handler won't re-fire
        _showUnsavedDialog = false;
        var url = _pendingNavUrl ?? "/scripts";
        _pendingNavUrl = null;
        Nav.NavigateTo(url);
    }

    private void KeepEditing()
    {
        _showUnsavedDialog = false;
        _pendingNavUrl = null;
    }

    public void Dispose() => _locationChangingReg?.Dispose();

    private void SaveScript()
    {
        if (string.IsNullOrWhiteSpace(_script.Name))
        {
            _validationError = "Script name is required.";
            return;
        }
        if (string.IsNullOrWhiteSpace(_script.Content))
        {
            _validationError = "Script content is required.";
            return;
        }

        _script.Tags = _tagsText
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .ToList();

        if (_isNew)
        {
            _script.Id = Guid.NewGuid();
            ScriptService.AddScript(_script);
            _ = AuditService.LogAsync("Script.Created", _script.Name, _script.Language.ToDisplayName(), _username);
        }
        else
        {
            ScriptService.UpdateScript(_script);
            _ = AuditService.LogAsync("Script.Updated", _script.Name, _script.Language.ToDisplayName(), _username);
        }

        CaptureSnapshot(); // makes IsDirty false so the handler doesn't block the save navigation
        Nav.NavigateTo("/scripts");
    }

    // ── AI assistant ─────────────────────────────────────────────────────────

    private int _aiMode;
    private string _aiPrompt      = string.Empty;
    private string _aiExplanation = string.Empty;
    private string _aiError       = string.Empty;
    private bool _aiRunning;
    private CancellationTokenSource? _aiCts;

    private async Task RunAi()
    {
        _aiError = string.Empty;
        _aiExplanation = string.Empty;

        string system, user;
        var lang = _script.Language.ToDisplayName();

        switch (_aiMode)
        {
            case 0: // Generate
                if (!string.IsNullOrWhiteSpace(_script.Content))
                {
                    _script.Content = string.Empty;
                    await InvokeAsync(StateHasChanged);
                }
                system = $"Output ONLY raw {lang} script code with no markdown fences and no explanation.";
                user   = _aiPrompt;
                break;

            case 1: // Improve
                system = $"Output ONLY the improved raw {lang} script code with no markdown fences and no explanation.";
                user   = $"Script:\n{_script.Content}\n\nInstructions: {_aiPrompt}";
                _script.Content = string.Empty;
                await InvokeAsync(StateHasChanged);
                break;

            default: // Explain
                system = "You are a helpful assistant. Be concise and clear.";
                user   = $"Explain what this {lang} script does in plain language suitable for an operator:\n\n{_script.Content}";
                break;
        }

        _aiRunning = true;
        _aiCts = new CancellationTokenSource();

        try
        {
            await foreach (var token in Claude.StreamAsync(system, user, _aiCts.Token))
            {
                if (_aiMode == 2)
                    _aiExplanation += token;
                else
                    _script.Content += token;

                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            _aiError = ex.Message;
        }
        finally
        {
            _aiRunning = false;
            _aiCts?.Dispose();
            _aiCts = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void CancelAi() => _aiCts?.Cancel();
}
