@page "/"
@attribute [Authorize]
@rendermode InteractiveServer
@inject IScriptRunnerService ScriptService
@inject IJobSchedulerService Scheduler

<PageTitle>Dashboard - Automator</PageTitle>

<h4 class="mb-4">Dashboard</h4>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card text-bg-primary h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <i class="bi bi-collection-fill fs-2"></i>
                <div>
                    <div class="fs-2 fw-bold">@ScriptService.Scripts.Count</div>
                    <div class="small opacity-75">Scripts</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-bg-success h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <i class="bi bi-check-circle-fill fs-2"></i>
                <div>
                    <div class="fs-2 fw-bold">@SuccessCount</div>
                    <div class="small opacity-75">Successful Runs</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-bg-danger h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <i class="bi bi-x-circle-fill fs-2"></i>
                <div>
                    <div class="fs-2 fw-bold">@FailureCount</div>
                    <div class="small opacity-75">Failed Runs</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-bg-warning h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <i class="bi bi-arrow-repeat fs-2"></i>
                <div>
                    <div class="fs-2 fw-bold">@RunningCount</div>
                    <div class="small opacity-75">Running Now</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-bg-info h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <i class="bi bi-calendar-check fs-2"></i>
                <div>
                    <div class="fs-2 fw-bold">@Scheduler.Jobs.Count(j => j.IsEnabled)</div>
                    <div class="small opacity-75">Active Schedules</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header fw-semibold">
                <i class="bi bi-collection me-2"></i>Scripts by Language
            </div>
            <div class="card-body">
                @foreach (var lang in Enum.GetValues<ScriptLanguage>())
                {
                    var count = ScriptService.Scripts.Count(s => s.Language == lang);
                    <div class="d-flex align-items-center mb-2 gap-2">
                        <span class="badge @lang.ToBadgeClass() text-nowrap" style="width: 110px;">@lang.ToDisplayName()</span>
                        <div class="progress flex-grow-1" style="height: 18px;">
                            <div class="progress-bar @lang.ToBadgeClass()"
                                 style="width: @(ScriptService.Scripts.Count > 0 ? (count * 100 / ScriptService.Scripts.Count) : 0)%">
                            </div>
                        </div>
                        <span class="text-muted small" style="width: 20px;">@count</span>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header fw-semibold">
                <i class="bi bi-clock-history me-2"></i>Recent Executions
            </div>
            <div class="card-body p-0">
                @if (!ScriptService.ExecutionHistory.Any())
                {
                    <div class="p-3 text-muted">No executions yet. <a href="/runner">Run a script</a> to get started.</div>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var run in ScriptService.ExecutionHistory.Take(5))
                        {
                            <li class="list-group-item d-flex align-items-center gap-2">
                                @if (run.IsRunning)
                                {
                                    <span class="spinner-border spinner-border-sm text-warning"></span>
                                }
                                else if (run.IsSuccess)
                                {
                                    <i class="bi bi-check-circle-fill text-success"></i>
                                }
                                else
                                {
                                    <i class="bi bi-x-circle-fill text-danger"></i>
                                }
                                <div class="flex-grow-1">
                                    <div class="fw-semibold small">@run.ScriptName</div>
                                    <div class="text-muted" style="font-size: 0.75rem;">
                                        @run.StartedAt.ToLocalTime().ToString("g")
                                        @if (run.Duration.HasValue)
                                        {
                                            <span> &bull; @run.Duration.Value.TotalSeconds.ToString("F1")s</span>
                                        }
                                    </div>
                                </div>
                                <span class="badge @run.Language.ToBadgeClass()">@run.Language.ToDisplayName()</span>
                            </li>
                        }
                    </ul>
                }
            </div>
            <div class="card-footer">
                <a href="/history" class="btn btn-sm btn-outline-secondary">View all history</a>
            </div>
        </div>
    </div>
</div>

@code {
    private int SuccessCount => ScriptService.ExecutionHistory.Count(r => !r.IsRunning && r.IsSuccess);
    private int FailureCount => ScriptService.ExecutionHistory.Count(r => !r.IsRunning && !r.IsSuccess);
    private int RunningCount => ScriptService.ExecutionHistory.Count(r => r.IsRunning);
}
