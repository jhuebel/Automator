@page "/"
@attribute [Authorize]
@inject IScriptRunnerService ScriptService
@inject IJobSchedulerService Scheduler

<PageTitle>Dashboard - Automator</PageTitle>

<MudText Typo="Typo.h5" Class="mb-3">Dashboard</MudText>

@if (!ScriptService.Scripts.Any())
{
    <MudAlert Severity="Severity.Info" Icon="@Icons.Material.Filled.Lightbulb" Class="mb-3">
        <MudText><strong>Welcome to Automator!</strong> Here's how to get started:</MudText>
        <ol style="margin: 0.5rem 0 0; padding-left: 1.25rem; font-size: 0.875rem;">
            <li>Open <MudLink Href="/scripts">Script Library</MudLink> to browse or create scripts</li>
            <li>Head to <MudLink Href="/runner">Run Script</MudLink> to execute one on demand</li>
            <li>Set up <MudLink Href="/jobs">Scheduled Jobs</MudLink> to automate recurring tasks</li>
            <li>Check <MudLink Href="/settings?tab=status">System Status</MudLink> to verify required runtimes are installed</li>
        </ol>
    </MudAlert>
}

<MudCard Class="mb-4" Elevation="1">
    <MudCardHeader>
        <CardHeaderContent>
            <div style="display: flex; align-items: center; justify-content: space-between;">
                <div style="display: flex; align-items: center; gap: 0.5rem;">
                    <MudIcon Icon="@Icons.Material.Filled.BarChart" />
                    <MudText Typo="Typo.h6">Executions Over Time</MudText>
                </div>
                <MudText Typo="Typo.caption" Color="Color.Secondary">Last 14 days</MudText>
            </div>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent Style="padding-top: 0; padding-bottom: 60px;">
        <div style="width: 100%; height: 260px; overflow: visible;">
            <MudChart T="double"
                      ChartType="ChartType.StackedBar"
                      ChartSeries="@_chartSeries"
                      ChartLabels="@_chartLabels"
                      Width="100%" Height="100%"
                      MatchBoundsToSize="true"
                      ChartOptions="@_chartOptions" />
        </div>
    </MudCardContent>
</MudCard>

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 1rem; margin-bottom: 1.5rem;">
    <a href="/scripts" style="text-decoration: none;">
        <MudCard Elevation="1" Style="border-top: 4px solid var(--mud-palette-primary);">
            <MudCardContent Style="display: flex; align-items: center; gap: 1rem;">
                <MudIcon Icon="@Icons.Material.Filled.LibraryBooks" Color="Color.Primary" Size="Size.Large" />
                <div>
                    <MudText Typo="Typo.h4" Color="Color.Primary">@ScriptService.Scripts.Count</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Scripts</MudText>
                </div>
            </MudCardContent>
        </MudCard>
    </a>
    <a href="/history" style="text-decoration: none;">
        <MudCard Elevation="1" Style="border-top: 4px solid var(--mud-palette-success);">
            <MudCardContent Style="display: flex; align-items: center; gap: 1rem;">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Large" />
                <div>
                    <MudText Typo="Typo.h4" Color="Color.Success">@SuccessCount</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Successful Runs</MudText>
                </div>
            </MudCardContent>
        </MudCard>
    </a>
    <a href="/history" style="text-decoration: none;">
        <MudCard Elevation="1" Style="border-top: 4px solid var(--mud-palette-error);">
            <MudCardContent Style="display: flex; align-items: center; gap: 1rem;">
                <MudIcon Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Size="Size.Large" />
                <div>
                    <MudText Typo="Typo.h4" Color="Color.Error">@FailureCount</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Failed Runs</MudText>
                </div>
            </MudCardContent>
        </MudCard>
    </a>
    <a href="/runner" style="text-decoration: none;">
        <MudCard Elevation="1" Style="border-top: 4px solid var(--mud-palette-warning);">
            <MudCardContent Style="display: flex; align-items: center; gap: 1rem;">
                <MudIcon Icon="@Icons.Material.Filled.Autorenew" Color="Color.Warning" Size="Size.Large" />
                <div>
                    <MudText Typo="Typo.h4" Color="Color.Warning">@RunningCount</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Running Now</MudText>
                </div>
            </MudCardContent>
        </MudCard>
    </a>
    <a href="/jobs" style="text-decoration: none;">
        <MudCard Elevation="1" Style="border-top: 4px solid var(--mud-palette-info);">
            <MudCardContent Style="display: flex; align-items: center; gap: 1rem;">
                <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Color="Color.Info" Size="Size.Large" />
                <div>
                    <MudText Typo="Typo.h4" Color="Color.Info">@Scheduler.Jobs.Count(j => j.IsEnabled)</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Active Schedules</MudText>
                </div>
            </MudCardContent>
        </MudCard>
    </a>
</div>

<MudGrid Spacing="3">
    <MudItem xs="12" md="6">
        <MudCard Elevation="1" Class="h-100">
            <MudCardHeader>
                <CardHeaderContent>
                    <div style="display: flex; align-items: center; gap: 0.5rem;">
                        <MudIcon Icon="@Icons.Material.Filled.LibraryBooks" Size="Size.Small" />
                        <MudText Typo="Typo.h6">Scripts by Language</MudText>
                    </div>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                @foreach (var lang in Enum.GetValues<ScriptLanguage>())
                {
                    var count = ScriptService.Scripts.Count(s => s.Language == lang);
                    var pct = ScriptService.Scripts.Count > 0 ? (double)count * 100 / ScriptService.Scripts.Count : 0;
                    <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem;">
                        <MudChip T="string" Color="@lang.ToColor()" Size="Size.Small"
                                 Style="width: 120px; justify-content: center;">@lang.ToDisplayName()</MudChip>
                        <MudProgressLinear Color="@lang.ToColor()" Rounded="true" Size="Size.Medium"
                                           Value="@pct" Style="flex: 1;" />
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Style="width: 20px; text-align: right;">@count</MudText>
                    </div>
                }
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" md="6">
        <MudCard Elevation="1" Class="h-100">
            <MudCardHeader>
                <CardHeaderContent>
                    <div style="display: flex; align-items: center; gap: 0.5rem;">
                        <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Small" />
                        <MudText Typo="Typo.h6">Recent Executions</MudText>
                    </div>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent Style="padding: 0;">
                @if (!ScriptService.ExecutionHistory.Any())
                {
                    <div style="padding: 1rem;">
                        <MudText Color="Color.Secondary">No executions yet. <MudLink Href="/runner">Run a script</MudLink> to get started.</MudText>
                    </div>
                }
                else
                {
                    <MudList T="string" Dense="true" Padding="false">
                        @foreach (var run in ScriptService.ExecutionHistory.Take(5))
                        {
                            <MudListItem T="string">
                                <div style="display: flex; align-items: center; gap: 0.75rem; width: 100%;">
                                    @if (run.IsRunning)
                                    {
                                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Warning" />
                                    }
                                    else if (run.IsSuccess)
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                                    }
                                    else
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Size="Size.Small" />
                                    }
                                    <div style="flex: 1; min-width: 0;">
                                        <MudText Typo="Typo.body2" Style="font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@run.ScriptName</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            @run.StartedAt.ToLocalTime().ToString("g")
                                            @if (run.Duration.HasValue)
                                            {
                                                <span> · @run.Duration.Value.TotalSeconds.ToString("F1")s</span>
                                            }
                                        </MudText>
                                    </div>
                                    <MudChip T="string" Color="@run.Language.ToColor()" Size="Size.Small">@run.Language.ToDisplayName()</MudChip>
                                </div>
                            </MudListItem>
                            <MudDivider />
                        }
                    </MudList>
                }
            </MudCardContent>
            <MudCardActions>
                <MudButton Href="/history" Variant="Variant.Outlined" Size="Size.Small" Color="Color.Default">View all history</MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    private int SuccessCount => ScriptService.ExecutionHistory.Count(r => !r.IsRunning && r.IsSuccess);
    private int FailureCount => ScriptService.ExecutionHistory.Count(r => !r.IsRunning && !r.IsSuccess);
    private int RunningCount => ScriptService.ExecutionHistory.Count(r => r.IsRunning);

    private List<ChartSeries<double>> _chartSeries = [];
    private string[] _chartLabels = [];
    private readonly StackedBarChartOptions _chartOptions = new()
    {
        ChartPalette = ["#198754", "#dc3545"]
    };

    protected override void OnInitialized()
    {
        var history = ScriptService.ExecutionHistory.Where(r => !r.IsRunning).ToList();
        var today   = DateTime.Now.Date;
        var labels  = new List<string>();
        var success = new List<double>();
        var failed  = new List<double>();

        for (int i = 13; i >= 0; i--)
        {
            var date = today.AddDays(-i);
            var day  = history.Where(r => r.StartedAt.ToLocalTime().Date == date).ToList();
            labels.Add(date.ToString("MMM d"));
            success.Add(day.Count(r => r.IsSuccess));
            failed.Add(day.Count(r => !r.IsSuccess));
        }

        _chartLabels = [.. labels];
        _chartSeries =
        [
            new ChartSeries<double> { Name = "Successful", Data = new ChartData<double>(success) },
            new ChartSeries<double> { Name = "Failed",      Data = new ChartData<double>(failed)  }
        ];
    }
}
