@page "/jobs"
@attribute [Authorize]
@inject IJobSchedulerService Scheduler
@inject IScriptRunnerService ScriptService
@inject IAuditLogService AuditService
@inject NavigationManager Nav

<PageTitle>Scheduled Jobs - Automator</PageTitle>

<div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem;">
    <MudText Typo="Typo.h5" Style="margin: 0;">Scheduled Jobs</MudText>
    <AuthorizeView Roles="Admin,Developer,Operator">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                   OnClick="NewJob">New Job</MudButton>
    </AuthorizeView>
</div>

<PageHelp>
    Jobs fire automatically when their cron schedule is due. The scheduler checks every 15 seconds.
    <ul style="margin: 0.25rem 0 0; padding-left: 1.25rem;">
        <li>Disable a job to pause it without deleting it</li>
        <li>Use <strong>Run Now</strong> to trigger a job immediately outside its schedule</li>
        <li>Jobs share the same execution environment as manually-run scripts</li>
    </ul>
</PageHelp>

@if (IsEditing)
{
    <MudCard Class="mb-4" Elevation="2" Style="border-top: 4px solid var(--mud-palette-primary);">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">@(EditingJob.Id == Guid.Empty ? "New Scheduled Job" : $"Edit: {EditingJob.Name}")</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            <MudGrid Spacing="2">
                <MudItem xs="12" md="5">
                    <MudTextField @bind-Value="EditingJob.Name" Label="Job Name" Variant="Variant.Outlined"
                                  Margin="Margin.Dense" Placeholder="e.g. Nightly Disk Check" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSelect T="Guid" @bind-Value="EditingJob.ScriptId" Label="Script"
                               Variant="Variant.Outlined" Margin="Margin.Dense">
                        <MudSelectItem T="Guid" Value="@Guid.Empty">— select a script —</MudSelectItem>
                        @foreach (var script in ScriptService.Scripts.OrderBy(s => s.Name))
                        {
                            <MudSelectItem T="Guid" Value="@script.Id">@script.Name (@script.Language.ToDisplayName())</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="3" Style="display: flex; align-items: center;">
                    <MudSwitch T="bool" @bind-Value="EditingJob.IsEnabled" Color="Color.Primary"
                               Label="@(EditingJob.IsEnabled ? "Active" : "Paused")" />
                </MudItem>
                <MudItem xs="12">
                    <MudText Typo="Typo.body2" Style="font-weight: 600; margin-bottom: 0.25rem;">
                        Cron Expression
                        <HelpIcon Text="5 fields: minute (0-59) · hour (0-23) · day-of-month (1-31) · month (1-12) · weekday (0-6, Sun=0). Use * for any, */n for every nth, or comma-separate values. Example: '0 2 * * 1' = every Monday at 2 am." />
                    </MudText>
                    <div style="display: flex; align-items: center; gap: 0.5rem; max-width: 380px;">
                        <MudTextField @bind-Value="EditingJob.CronExpression" Label="min hr day mo dow"
                                      Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true"
                                      Class="font-monospace" Placeholder="0 * * * *" Style="flex: 1;" />
                    </div>
                    <div style="display: flex; flex-wrap: wrap; gap: 0.25rem; margin-top: 0.5rem;">
                        @foreach (var preset in CronPresets)
                        {
                            <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Default"
                                       OnClick="() => ApplyPreset(preset.Cron)">@preset.Label</MudButton>
                        }
                    </div>
                </MudItem>
            </MudGrid>

            @if (!string.IsNullOrWhiteSpace(EditingJob.CronExpression))
            {
                var next = Scheduler.GetNextOccurrence(EditingJob.CronExpression);
                @if (next.HasValue)
                {
                    <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">
                        Next run: <strong>@next.Value.ToLocalTime().ToString("f")</strong>
                        (@FormatTimeUntil(next.Value))
                    </MudAlert>
                }
                else
                {
                    <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-2">
                        Invalid cron expression. Use 5 fields: minute hour day month day-of-week.
                    </MudAlert>
                }
            }

            @if (!string.IsNullOrEmpty(ValidationError))
            {
                <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2">@ValidationError</MudAlert>
            }
        </MudCardContent>
        <MudCardActions>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save"
                       OnClick="SaveJob">Save</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="CancelEdit">Cancel</MudButton>
        </MudCardActions>
    </MudCard>
}

@if (!Scheduler.Jobs.Any())
{
    <MudText Color="Color.Secondary">No scheduled jobs yet. Click "New Job" to create one.</MudText>
}
else
{
    <MudPaper Elevation="1" Class="overflow-auto">
        <MudSimpleTable Hover="true" Dense="true">
            <thead>
                <tr>
                    <th style="width: 80px;">Enabled</th>
                    <th>Name</th>
                    <th>Script</th>
                    <th>Schedule</th>
                    <th>Next Run</th>
                    <th>Last Run</th>
                    <th>Last Result</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var job in Scheduler.Jobs.OrderBy(j => j.Name))
                {
                    var script = ScriptService.GetScript(job.ScriptId);
                    <tr style="@(job.IsEnabled ? "" : "opacity: 0.65;")">
                        <td>
                            <AuthorizeView Roles="Admin,Developer,Operator">
                                <Authorized>
                                    <MudSwitch T="bool" Value="@job.IsEnabled"
                                               ValueChanged="() => ToggleEnabled(job)"
                                               Color="Color.Primary" Size="Size.Small" />
                                </Authorized>
                                <NotAuthorized>
                                    <MudChip T="string" Color="@(job.IsEnabled ? Color.Success : Color.Default)" Size="Size.Small">
                                        @(job.IsEnabled ? "On" : "Off")
                                    </MudChip>
                                </NotAuthorized>
                            </AuthorizeView>
                        </td>
                        <td style="font-weight: 600;">@job.Name</td>
                        <td>
                            @if (script is not null)
                            {
                                <MudChip T="string" Color="@script.Language.ToColor()" Size="Size.Small">@script.Language.ToDisplayName()</MudChip>
                                <span style="margin-left: 0.25rem; font-size: 0.875rem;">@script.Name</span>
                            }
                            else
                            {
                                <MudText Color="Color.Error" Typo="Typo.caption">Script not found</MudText>
                            }
                        </td>
                        <td><code style="font-size: 0.8rem;">@job.CronExpression</code></td>
                        <td style="white-space: nowrap; font-size: 0.875rem;">
                            @if (job.IsEnabled && job.NextRunAt.HasValue)
                            {
                                <span title="@job.NextRunAt.Value.ToLocalTime().ToString("f")">@FormatTimeUntil(job.NextRunAt.Value)</span>
                            }
                            else
                            {
                                <MudText Color="Color.Secondary" Typo="Typo.body2">—</MudText>
                            }
                        </td>
                        <td style="white-space: nowrap; font-size: 0.875rem; color: var(--mud-palette-text-secondary);">
                            @(job.LastRunAt.HasValue ? job.LastRunAt.Value.ToLocalTime().ToString("g") : "Never")
                        </td>
                        <td>
                            @if (job.LastExitCode.HasValue)
                            {
                                <MudChip T="string" Color="@(job.LastRunSucceeded ? Color.Success : Color.Error)" Size="Size.Small">
                                    exit @job.LastExitCode
                                </MudChip>
                            }
                            else
                            {
                                <MudText Color="Color.Secondary" Typo="Typo.caption">—</MudText>
                            }
                        </td>
                        <td>
                            <AuthorizeView Roles="Admin,Developer,Operator">
                                <div style="display: flex; gap: 0.125rem;">
                                    @if (script is not null)
                                    {
                                        <MudIconButton Icon="@Icons.Material.Filled.PlayArrow" Color="Color.Success"
                                                       Size="Size.Small" OnClick="() => RunNow(job)" />
                                    }
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary"
                                                   Size="Size.Small" OnClick="() => EditJob(job)" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                                   Size="Size.Small" OnClick="() => ConfirmDelete(job)" />
                                </div>
                            </AuthorizeView>
                        </td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    </MudPaper>
}

@if (DeletingJob is not null)
{
    <div style="position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 1000; display: flex; align-items: center; justify-content: center;">
        <MudCard Style="width: 380px;">
            <MudCardHeader>
                <CardHeaderContent><MudText Typo="Typo.h6">Confirm Delete</MudText></CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                Delete job <strong>@DeletingJob.Name</strong>? This cannot be undone.
            </MudCardContent>
            <MudCardActions>
                <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="DeleteConfirmed">Delete</MudButton>
                <MudButton Variant="Variant.Outlined" OnClick="() => DeletingJob = null">Cancel</MudButton>
            </MudCardActions>
        </MudCard>
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private string _username = string.Empty;

    private ScheduledJob EditingJob { get; set; } = new() { Id = Guid.Empty };
    private bool IsEditing { get; set; }
    private string ValidationError { get; set; } = string.Empty;
    private ScheduledJob? DeletingJob { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is not null)
            _username = (await AuthState).User.Identity?.Name ?? string.Empty;
    }

    private static readonly (string Label, string Cron)[] CronPresets =
    [
        ("Every minute",    "* * * * *"),
        ("Every 5 min",     "*/5 * * * *"),
        ("Every hour",      "0 * * * *"),
        ("Daily midnight",  "0 0 * * *"),
        ("Daily 8am",       "0 8 * * *"),
        ("Weekly Sunday",   "0 0 * * 0"),
        ("Monthly 1st",     "0 0 1 * *"),
    ];

    private void NewJob()
    {
        EditingJob = new ScheduledJob { Id = Guid.Empty };
        ValidationError = string.Empty;
        IsEditing = true;
    }

    private void EditJob(ScheduledJob job)
    {
        EditingJob = new ScheduledJob
        {
            Id = job.Id,
            Name = job.Name,
            ScriptId = job.ScriptId,
            CronExpression = job.CronExpression,
            IsEnabled = job.IsEnabled,
            LastRunAt = job.LastRunAt,
            NextRunAt = job.NextRunAt,
            LastExitCode = job.LastExitCode,
            CreatedAt = job.CreatedAt
        };
        ValidationError = string.Empty;
        IsEditing = true;
    }

    private void SaveJob()
    {
        if (string.IsNullOrWhiteSpace(EditingJob.Name))
        {
            ValidationError = "Job name is required.";
            return;
        }
        if (EditingJob.ScriptId == Guid.Empty)
        {
            ValidationError = "Please select a script.";
            return;
        }
        if (Scheduler.GetNextOccurrence(EditingJob.CronExpression) is null)
        {
            ValidationError = "Cron expression is invalid or empty.";
            return;
        }

        if (EditingJob.Id == Guid.Empty)
        {
            EditingJob.Id = Guid.NewGuid();
            Scheduler.AddJob(EditingJob);
            _ = AuditService.LogAsync("Job.Created", EditingJob.Name, EditingJob.CronExpression, _username);
        }
        else
        {
            Scheduler.UpdateJob(EditingJob);
            _ = AuditService.LogAsync("Job.Updated", EditingJob.Name, EditingJob.CronExpression, _username);
        }

        IsEditing = false;
    }

    private void CancelEdit() => IsEditing = false;

    private void ApplyPreset(string cron) => EditingJob.CronExpression = cron;

    private void ToggleEnabled(ScheduledJob job)
    {
        job.IsEnabled = !job.IsEnabled;
        if (job.IsEnabled)
            job.NextRunAt = Scheduler.GetNextOccurrence(job.CronExpression);
        Scheduler.UpdateJob(job);
        _ = AuditService.LogAsync(job.IsEnabled ? "Job.Enabled" : "Job.Disabled", job.Name, null, _username);
    }

    private void RunNow(ScheduledJob job) =>
        Nav.NavigateTo($"/runner/{job.ScriptId}");

    private void ConfirmDelete(ScheduledJob job) => DeletingJob = job;

    private void DeleteConfirmed()
    {
        if (DeletingJob is not null)
        {
            Scheduler.DeleteJob(DeletingJob.Id);
            _ = AuditService.LogAsync("Job.Deleted", DeletingJob.Name, null, _username);
            DeletingJob = null;
        }
    }

    private static string FormatTimeUntil(DateTime utc)
    {
        var diff = utc - DateTime.UtcNow;
        if (diff.TotalSeconds < 0) return "overdue";
        if (diff.TotalMinutes < 1) return $"{(int)diff.TotalSeconds}s";
        if (diff.TotalHours < 1) return $"{(int)diff.TotalMinutes}m";
        if (diff.TotalDays < 1) return $"{(int)diff.TotalHours}h {diff.Minutes}m";
        return $"{(int)diff.TotalDays}d {diff.Hours}h";
    }
}
