@page "/help"
@attribute [Authorize]

<PageTitle>Help - Automator</PageTitle>

<MudText Typo="Typo.h5" Class="mb-1">Help &amp; Documentation</MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
    Reference for every page in Automator. Sections are filtered to your role — you will only see features you have access to.
</MudText>

<MudExpansionPanels MultiExpansion="true">
    <MudExpansionPanel @bind-Expanded="_dashboard">
        <TitleContent>
            <div style="display:flex; align-items:center; gap:0.5rem;">
                <MudIcon Icon="@Icons.Material.Filled.Dashboard" Size="Size.Small" />
                <MudText Typo="Typo.subtitle1">Dashboard</MudText>
            </div>
        </TitleContent>
        <ChildContent>
            <div class="pa-2"><HelpDashboard /></div>
        </ChildContent>
    </MudExpansionPanel>

    <MudExpansionPanel @bind-Expanded="_scripts">
        <TitleContent>
            <div style="display:flex; align-items:center; gap:0.5rem;">
                <MudIcon Icon="@Icons.Material.Filled.LibraryBooks" Size="Size.Small" />
                <MudText Typo="Typo.subtitle1">Script Library</MudText>
            </div>
        </TitleContent>
        <ChildContent>
            <div class="pa-2"><HelpScriptLibrary /></div>
        </ChildContent>
    </MudExpansionPanel>

    <AuthorizeView Roles="Admin,Developer,Operator">
        <MudExpansionPanel @bind-Expanded="_runner">
            <TitleContent>
                <div style="display:flex; align-items:center; gap:0.5rem;">
                    <MudIcon Icon="@Icons.Material.Filled.PlayCircle" Size="Size.Small" />
                    <MudText Typo="Typo.subtitle1">Run Script</MudText>
                </div>
            </TitleContent>
            <ChildContent>
                <div class="pa-2"><HelpRunner /></div>
            </ChildContent>
        </MudExpansionPanel>

        <MudExpansionPanel @bind-Expanded="_jobs">
            <TitleContent>
                <div style="display:flex; align-items:center; gap:0.5rem;">
                    <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" />
                    <MudText Typo="Typo.subtitle1">Scheduled Jobs</MudText>
                </div>
            </TitleContent>
            <ChildContent>
                <div class="pa-2"><HelpJobs /></div>
            </ChildContent>
        </MudExpansionPanel>
    </AuthorizeView>

    <MudExpansionPanel @bind-Expanded="_history">
        <TitleContent>
            <div style="display:flex; align-items:center; gap:0.5rem;">
                <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Small" />
                <MudText Typo="Typo.subtitle1">Execution History</MudText>
            </div>
        </TitleContent>
        <ChildContent>
            <div class="pa-2"><HelpHistory /></div>
        </ChildContent>
    </MudExpansionPanel>

    <MudExpansionPanel @bind-Expanded="_profile">
        <TitleContent>
            <div style="display:flex; align-items:center; gap:0.5rem;">
                <MudIcon Icon="@Icons.Material.Filled.ManageAccounts" Size="Size.Small" />
                <MudText Typo="Typo.subtitle1">My Account</MudText>
            </div>
        </TitleContent>
        <ChildContent>
            <div class="pa-2"><HelpProfile /></div>
        </ChildContent>
    </MudExpansionPanel>

    <AuthorizeView Roles="Admin">
        <MudExpansionPanel @bind-Expanded="_settings">
            <TitleContent>
                <div style="display:flex; align-items:center; gap:0.5rem;">
                    <MudIcon Icon="@Icons.Material.Filled.Settings" Size="Size.Small" />
                    <MudText Typo="Typo.subtitle1">Settings</MudText>
                </div>
            </TitleContent>
            <ChildContent>
                <div class="pa-2"><HelpSettings /></div>
            </ChildContent>
        </MudExpansionPanel>
    </AuthorizeView>
</MudExpansionPanels>

@code {
    private bool _dashboard = true;
    private bool _scripts   = true;
    private bool _runner    = true;
    private bool _jobs      = true;
    private bool _history   = true;
    private bool _profile   = true;
    private bool _settings  = true;
}
