@inject IDependencyCheckService DependencyService

<PageHelp>
    This panel checks that the script interpreters and database are reachable by the application process.
    Missing runtimes prevent scripts of that language from running.
    <ul style="margin: 0.25rem 0 0; padding-left: 1.25rem;">
        <li><strong>Bash</strong> — pre-installed on Linux/macOS; on Windows use Git Bash or WSL</li>
        <li><strong>PowerShell</strong> — install PowerShell 7+ from <code>github.com/PowerShell/PowerShell</code></li>
        <li><strong>Python</strong> — install Python 3 from <code>python.org</code> or your system package manager</li>
        <li><strong>Ansible</strong> — install via pip: <code>pip install ansible</code></li>
        <li><strong>Terraform</strong> — install from <code>developer.hashicorp.com/terraform/install</code></li>
    </ul>
</PageHelp>

<div style="display: flex; justify-content: flex-end; margin-bottom: 1rem;">
    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Refresh"
               OnClick="RunChecks" Disabled="@IsChecking">
        @if (IsChecking)
        {
            <span>Checking...</span>
        }
        else
        {
            <span>Re-check</span>
        }
    </MudButton>
</div>

@if (IsChecking && Runtimes is null)
{
    <div style="display: flex; align-items: center; gap: 0.5rem;">
        <MudProgressCircular Size="Size.Small" Indeterminate="true" />
        <MudText Color="Color.Secondary">Running dependency checks...</MudText>
    </div>
}
else
{
    <MudGrid Spacing="3">
        @if (Runtimes is not null)
        {
            <MudItem xs="12">
                <MudCard Elevation="1">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <div style="display: flex; align-items: center; gap: 0.5rem;">
                                <MudIcon Icon="@Icons.Material.Filled.Terminal" Size="Size.Small" />
                                <MudText Typo="Typo.h6">Script Runtimes</MudText>
                            </div>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudPaper Elevation="0" Class="overflow-auto">
                        <MudSimpleTable Hover="true" Dense="true">
                            <thead>
                                <tr>
                                    <th style="width: 48px;"></th>
                                    <th>Runtime</th>
                                    <th>Description</th>
                                    <th>Version</th>
                                    <th>Path</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in Runtimes)
                                {
                                    <tr>
                                        <td>
                                            @if (r.IsAvailable)
                                            {
                                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" />
                                            }
                                            else
                                            {
                                                <MudIcon Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" />
                                            }
                                        </td>
                                        <td>
                                            <div style="display: flex; align-items: center; gap: 0.5rem;">
                                                @if (r.Language.HasValue)
                                                {
                                                    <MudChip T="string" Color="@r.Language.Value.ToColor()" Size="Size.Small">@r.Language.Value.ToDisplayName()</MudChip>
                                                }
                                                <span style="font-weight: 600;">@r.Name</span>
                                            </div>
                                        </td>
                                        <td style="font-size: 0.875rem; color: var(--mud-palette-text-secondary);">@r.Description</td>
                                        <td style="font-size: 0.8125rem; font-family: monospace;">
                                            @if (r.IsAvailable && r.Version is not null)
                                            {
                                                @r.Version
                                            }
                                            else if (!r.IsAvailable)
                                            {
                                                <MudText Color="Color.Error" Typo="Typo.caption">@r.ErrorMessage</MudText>
                                            }
                                        </td>
                                        <td style="font-size: 0.8125rem; font-family: monospace; color: var(--mud-palette-text-secondary);">
                                            @(r.Path ?? "—")
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                    </MudPaper>
                    <MudCardContent Style="padding: 0.75rem 1rem; border-top: 1px solid var(--mud-palette-divider);">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            Checked at @CheckedAt?.ToLocalTime().ToString("T")
                            · @Runtimes.Count(r => r.IsAvailable)/@Runtimes.Count available
                        </MudText>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }

        @if (DbStatus is not null)
        {
            <MudItem xs="12" md="5">
                <MudCard Elevation="1" Class="h-100">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <div style="display: flex; align-items: center; gap: 0.5rem;">
                                <MudIcon Icon="@Icons.Material.Filled.Storage" Size="Size.Small" />
                                <MudText Typo="Typo.h6">Database</MudText>
                            </div>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1rem;">
                            @if (DbStatus.IsAccessible)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" />
                                <MudText Color="Color.Success" Style="font-weight: 600;">Connected</MudText>
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" />
                                <MudText Color="Color.Error" Style="font-weight: 600;">Error</MudText>
                            }
                        </div>

                        <MudSimpleTable Dense="true" Elevation="0" Style="font-size: 0.8125rem;">
                            <tbody>
                                <tr>
                                    <td style="color: var(--mud-palette-text-secondary); width: 40%;">File</td>
                                    <td style="font-family: monospace;" title="@DbStatus.FilePath">@System.IO.Path.GetFileName(DbStatus.FilePath)</td>
                                </tr>
                                <tr>
                                    <td style="color: var(--mud-palette-text-secondary);">Size</td>
                                    <td>
                                        @if (DbStatus.FileSizeBytes.HasValue)
                                        {
                                            @FormatBytes(DbStatus.FileSizeBytes.Value)
                                        }
                                        else
                                        {
                                            <MudText Color="Color.Secondary" Typo="Typo.caption">File not found</MudText>
                                        }
                                    </td>
                                </tr>
                                <tr>
                                    <td style="color: var(--mud-palette-text-secondary);">Full path</td>
                                    <td style="font-family: monospace; font-size: 0.7rem; word-break: break-all;">@DbStatus.FilePath</td>
                                </tr>
                            </tbody>
                        </MudSimpleTable>

                        @if (!DbStatus.IsAccessible && DbStatus.ErrorMessage is not null)
                        {
                            <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2">@DbStatus.ErrorMessage</MudAlert>
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }

        <MudItem xs="12" md="7">
            <MudCard Elevation="1" Class="h-100">
                <MudCardHeader>
                    <CardHeaderContent>
                        <div style="display: flex; align-items: center; gap: 0.5rem;">
                            <MudIcon Icon="@Icons.Material.Filled.Memory" Size="Size.Small" />
                            <MudText Typo="Typo.h6">Application</MudText>
                        </div>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudSimpleTable Dense="true" Elevation="0" Style="font-size: 0.8125rem;">
                        <tbody>
                            <tr>
                                <td style="color: var(--mud-palette-text-secondary); width: 40%;">.NET Runtime</td>
                                <td style="font-family: monospace;">@System.Runtime.InteropServices.RuntimeInformation.FrameworkDescription</td>
                            </tr>
                            <tr>
                                <td style="color: var(--mud-palette-text-secondary);">OS</td>
                                <td style="font-family: monospace;">@System.Runtime.InteropServices.RuntimeInformation.OSDescription</td>
                            </tr>
                            <tr>
                                <td style="color: var(--mud-palette-text-secondary);">Architecture</td>
                                <td>@System.Runtime.InteropServices.RuntimeInformation.OSArchitecture</td>
                            </tr>
                            <tr>
                                <td style="color: var(--mud-palette-text-secondary);">CPU Cores</td>
                                <td>@Environment.ProcessorCount</td>
                            </tr>
                            <tr>
                                <td style="color: var(--mud-palette-text-secondary);">Working Dir</td>
                                <td style="font-family: monospace; font-size: 0.7rem; word-break: break-all;">@Environment.CurrentDirectory</td>
                            </tr>
                            <tr>
                                <td style="color: var(--mud-palette-text-secondary);">Server Time</td>
                                <td>@DateTime.Now.ToString("f") <MudText Inline="true" Color="Color.Secondary" Typo="Typo.caption">(local)</MudText></td>
                            </tr>
                        </tbody>
                    </MudSimpleTable>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
}

@code {
    private IReadOnlyList<DependencyCheckResult>? Runtimes { get; set; }
    private DatabaseStatus? DbStatus { get; set; }
    private DateTime? CheckedAt { get; set; }
    private bool IsChecking { get; set; }

    protected override async Task OnInitializedAsync() => await RunChecks();

    private async Task RunChecks()
    {
        IsChecking = true;
        StateHasChanged();

        try
        {
            var runtimesTask = DependencyService.CheckRuntimesAsync();
            var dbTask = DependencyService.GetDatabaseStatusAsync();
            await Task.WhenAll(runtimesTask, dbTask);

            Runtimes = await runtimesTask;
            DbStatus = await dbTask;
            CheckedAt = DateTime.UtcNow;
        }
        finally
        {
            IsChecking = false;
        }
    }

    private static string FormatBytes(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1_048_576) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / 1_048_576.0:F2} MB";
    }
}
