@inject IDependencyCheckService DependencyService

<PageHelp>
    This panel checks that the script interpreters and database are reachable by the application process.
    Missing runtimes prevent scripts of that language from running.
    <ul class="mb-0 mt-1 ps-3">
        <li><strong>Bash</strong> — pre-installed on Linux/macOS; on Windows use Git Bash or WSL</li>
        <li><strong>PowerShell</strong> — install PowerShell 7+ from <code>github.com/PowerShell/PowerShell</code></li>
        <li><strong>Python</strong> — install Python 3 from <code>python.org</code> or your system package manager</li>
        <li><strong>Ansible</strong> — install via pip: <code>pip install ansible</code></li>
    </ul>
</PageHelp>

<div class="d-flex justify-content-end mb-3">
    <button class="btn btn-outline-primary" @onclick="RunChecks" disabled="@IsChecking">
        @if (IsChecking)
        {
            <span class="spinner-border spinner-border-sm me-1"></span>
            <span>Checking...</span>
        }
        else
        {
            <i class="bi bi-arrow-clockwise me-1"></i>
            <span>Re-check</span>
        }
    </button>
</div>

@if (IsChecking && Runtimes is null)
{
    <div class="d-flex align-items-center gap-2 text-muted">
        <span class="spinner-border spinner-border-sm"></span>
        Running dependency checks...
    </div>
}
else
{
    <div class="row g-4">
        @if (Runtimes is not null)
        {
            <div class="col-12">
                <div class="card">
                    <div class="card-header fw-semibold">
                        <i class="bi bi-terminal me-2"></i>Script Runtimes
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 32px;"></th>
                                    <th>Runtime</th>
                                    <th>Description</th>
                                    <th>Version</th>
                                    <th>Path</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in Runtimes)
                                {
                                    <tr>
                                        <td>
                                            @if (r.IsAvailable)
                                            {
                                                <i class="bi bi-check-circle-fill text-success fs-5"></i>
                                            }
                                            else
                                            {
                                                <i class="bi bi-x-circle-fill text-danger fs-5"></i>
                                            }
                                        </td>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                @if (r.Language.HasValue)
                                                {
                                                    <span class="badge @r.Language.Value.ToBadgeClass()">@r.Language.Value.ToDisplayName()</span>
                                                }
                                                <span class="fw-semibold">@r.Name</span>
                                            </div>
                                        </td>
                                        <td class="text-muted small">@r.Description</td>
                                        <td class="font-monospace small">
                                            @if (r.IsAvailable && r.Version is not null)
                                            {
                                                @r.Version
                                            }
                                            else if (!r.IsAvailable)
                                            {
                                                <span class="text-danger">@r.ErrorMessage</span>
                                            }
                                        </td>
                                        <td class="font-monospace small text-muted">
                                            @(r.Path ?? "—")
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="card-footer text-muted small">
                        Checked at @CheckedAt?.ToLocalTime().ToString("T")
                        &bull; @Runtimes.Count(r => r.IsAvailable)/@Runtimes.Count available
                    </div>
                </div>
            </div>
        }

        @if (DbStatus is not null)
        {
            <div class="col-md-5">
                <div class="card h-100">
                    <div class="card-header fw-semibold">
                        <i class="bi bi-database me-2"></i>Database
                    </div>
                    <div class="card-body">
                        <div class="d-flex align-items-center gap-2 mb-3">
                            @if (DbStatus.IsAccessible)
                            {
                                <i class="bi bi-check-circle-fill text-success fs-5"></i>
                                <span class="fw-semibold text-success">Connected</span>
                            }
                            else
                            {
                                <i class="bi bi-x-circle-fill text-danger fs-5"></i>
                                <span class="fw-semibold text-danger">Error</span>
                            }
                        </div>

                        <dl class="row mb-0 small">
                            <dt class="col-5 text-muted">File</dt>
                            <dd class="col-7 font-monospace text-truncate" title="@DbStatus.FilePath">
                                @System.IO.Path.GetFileName(DbStatus.FilePath)
                            </dd>

                            <dt class="col-5 text-muted">Size</dt>
                            <dd class="col-7">
                                @if (DbStatus.FileSizeBytes.HasValue)
                                {
                                    @FormatBytes(DbStatus.FileSizeBytes.Value)
                                }
                                else
                                {
                                    <span class="text-muted">File not found</span>
                                }
                            </dd>

                            <dt class="col-5 text-muted">Full path</dt>
                            <dd class="col-7 font-monospace text-break" style="font-size: 0.7rem;">
                                @DbStatus.FilePath
                            </dd>
                        </dl>

                        @if (!DbStatus.IsAccessible && DbStatus.ErrorMessage is not null)
                        {
                            <div class="alert alert-danger py-2 small mt-2">@DbStatus.ErrorMessage</div>
                        }
                    </div>
                    @if (DbStatus.IsAccessible)
                    {
                        <div class="card-footer">
                            <div class="row text-center g-0">
                                <div class="col">
                                    <div class="fw-bold">@DbStatus.ScriptCount</div>
                                    <div class="text-muted" style="font-size: 0.7rem;">Scripts</div>
                                </div>
                                <div class="col border-start border-end">
                                    <div class="fw-bold">@DbStatus.JobCount</div>
                                    <div class="text-muted" style="font-size: 0.7rem;">Jobs</div>
                                </div>
                                <div class="col">
                                    <div class="fw-bold">@DbStatus.HistoryCount</div>
                                    <div class="text-muted" style="font-size: 0.7rem;">Executions</div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <div class="col-md-7">
            <div class="card h-100">
                <div class="card-header fw-semibold">
                    <i class="bi bi-cpu me-2"></i>Application
                </div>
                <div class="card-body">
                    <dl class="row mb-0 small">
                        <dt class="col-5 text-muted">.NET Runtime</dt>
                        <dd class="col-7 font-monospace">@System.Runtime.InteropServices.RuntimeInformation.FrameworkDescription</dd>

                        <dt class="col-5 text-muted">OS</dt>
                        <dd class="col-7 font-monospace">@System.Runtime.InteropServices.RuntimeInformation.OSDescription</dd>

                        <dt class="col-5 text-muted">Architecture</dt>
                        <dd class="col-7">@System.Runtime.InteropServices.RuntimeInformation.OSArchitecture</dd>

                        <dt class="col-5 text-muted">CPU Cores</dt>
                        <dd class="col-7">@Environment.ProcessorCount</dd>

                        <dt class="col-5 text-muted">Working Dir</dt>
                        <dd class="col-7 font-monospace text-break" style="font-size: 0.7rem;">@Environment.CurrentDirectory</dd>

                        <dt class="col-5 text-muted">Server Time</dt>
                        <dd class="col-7">@DateTime.Now.ToString("f") <span class="text-muted">(local)</span></dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private IReadOnlyList<DependencyCheckResult>? Runtimes { get; set; }
    private DatabaseStatus? DbStatus { get; set; }
    private DateTime? CheckedAt { get; set; }
    private bool IsChecking { get; set; }

    protected override async Task OnInitializedAsync() => await RunChecks();

    private async Task RunChecks()
    {
        IsChecking = true;
        StateHasChanged();

        try
        {
            var runtimesTask = DependencyService.CheckRuntimesAsync();
            var dbTask = DependencyService.GetDatabaseStatusAsync();
            await Task.WhenAll(runtimesTask, dbTask);

            Runtimes = await runtimesTask;
            DbStatus = await dbTask;
            CheckedAt = DateTime.UtcNow;
        }
        finally
        {
            IsChecking = false;
        }
    }

    private static string FormatBytes(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1_048_576) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / 1_048_576.0:F2} MB";
    }
}
