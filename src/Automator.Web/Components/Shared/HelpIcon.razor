<MudTooltip Text="@Text" Placement="Placement.Right" Arrow="true" RootStyle="display: inline;">
    <MudIcon Icon="@Icons.Material.Outlined.HelpOutline" Size="Size.Small" Color="Color.Info"
             Style="vertical-align: middle; font-size: 1rem; cursor: help;" />
</MudTooltip>

@code {
    [Parameter, EditorRequired] public string Text { get; set; } = string.Empty;
}
