<MudText Typo="Typo.h6" Class="mb-1">My Account</MudText>
@if (!Compact)
{
    <MudText Typo="Typo.body2" Class="mb-3" Color="Color.Secondary">
        Manage your own login credentials. Changes affect only your account.
        Contact an Admin to change your role or disable your account.
    </MudText>
}

<MudText Typo="Typo.subtitle2" Class="mt-2 mb-1">Changing Your Email</MudText>
<ol style="margin: 0 0 0.75rem; padding-left: 1.25rem; font-size: 0.875rem;">
    <li>Enter your new email address in the <strong>Email</strong> field.</li>
    <li>Click <strong>Update Email</strong>.</li>
    <li>The email is updated immediately — no confirmation link is sent.</li>
</ol>

<MudText Typo="Typo.subtitle2" Class="mt-2 mb-1">Changing Your Password</MudText>
<ol style="margin: 0 0 0.75rem; padding-left: 1.25rem; font-size: 0.875rem;">
    <li>Enter your current password.</li>
    <li>Enter and confirm your new password.</li>
    <li>Click <strong>Change Password</strong>.</li>
</ol>

@if (!Compact)
{
    <MudText Typo="Typo.subtitle2" Class="mt-2 mb-1">Password Requirements</MudText>
    <ul style="margin: 0; padding-left: 1.25rem; font-size: 0.875rem;">
        <li>Minimum 8 characters</li>
        <li>Must contain at least one digit (0–9)</li>
        <li>Uppercase, symbols, and spaces are optional</li>
    </ul>
}

@code {
    [Parameter] public bool Compact { get; set; }
}
