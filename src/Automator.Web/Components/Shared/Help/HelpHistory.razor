<MudText Typo="Typo.h6" Class="mb-1">Execution History</MudText>
@if (!Compact)
{
    <MudText Typo="Typo.body2" Class="mb-3" Color="Color.Secondary">
        A complete, searchable log of every script run — whether triggered manually or by a scheduled job.
        Visible to all roles.
    </MudText>
}

<MudText Typo="Typo.subtitle2" Class="mt-2 mb-1">Status Icons</MudText>
<ul style="margin: 0 0 0.75rem; padding-left: 1.25rem; font-size: 0.875rem;">
    <li><MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" Style="vertical-align:middle;" /> <strong>Green check</strong> — completed successfully (exit code 0)</li>
    <li><MudIcon Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Size="Size.Small" Style="vertical-align:middle;" /> <strong>Red X</strong> — failed (non-zero exit code)</li>
    <li><MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Warning" Style="vertical-align:middle;" /> <strong>Spinner</strong> — currently running</li>
</ul>

<MudText Typo="Typo.subtitle2" Class="mt-2 mb-1">Table Columns</MudText>
<ul style="margin: 0 0 0.75rem; padding-left: 1.25rem; font-size: 0.875rem;">
    <li><strong>Script</strong> — name of the script that was executed</li>
    <li><strong>Language</strong> — Bash, PowerShell, Python, or Ansible</li>
    <li><strong>Started</strong> — local time the run began</li>
    <li><strong>Duration</strong> — wall-clock time from start to finish</li>
    <li><strong>Exit Code</strong> — <code>0</code> = success; any other value = error</li>
    <li><strong>Output</strong> — click the button (or the whole row) to expand and view the full terminal output</li>
</ul>

@if (!Compact)
{
    <MudText Typo="Typo.subtitle2" Class="mt-2 mb-1">Tips</MudText>
    <ul style="margin: 0; padding-left: 1.25rem; font-size: 0.875rem;">
        <li>Click any row to toggle its output open or closed.</li>
        <li>Error output lines are shown in <span style="color:#f48771;">orange</span> inside the expanded view.</li>
        <li>The number of records retained is configurable in <MudLink Href="/settings">Settings → Application</MudLink>.</li>
    </ul>
}

@code {
    [Parameter] public bool Compact { get; set; }
}
