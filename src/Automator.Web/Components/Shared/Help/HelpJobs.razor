<MudText Typo="Typo.h6" Class="mb-1">Scheduled Jobs</MudText>
@if (!Compact)
{
    <MudText Typo="Typo.body2" Class="mb-3" Color="Color.Secondary">
        Schedule any script to run automatically on a recurring cron schedule.
        Available to <strong>Admins</strong>, <strong>Developers</strong>, and <strong>Operators</strong>.
    </MudText>
}

<MudText Typo="Typo.subtitle2" Class="mt-2 mb-1">Creating a Job</MudText>
<ol style="margin: 0 0 0.75rem; padding-left: 1.25rem; font-size: 0.875rem;">
    <li>Click <strong>New Job</strong>.</li>
    <li>Enter a name, select the script to run, and set the toggle to <strong>Active</strong>.</li>
    <li>Enter a cron expression or click one of the <strong>preset buttons</strong>.</li>
    <li>The <strong>Next occurrence</strong> preview updates as you type — verify it looks correct.</li>
    <li>Click <strong>Save</strong>.</li>
</ol>

<MudText Typo="Typo.subtitle2" Class="mt-2 mb-1">Cron Expression Format</MudText>
<MudText Typo="Typo.body2" Class="mb-1" Style="font-family: monospace;">minute · hour · day-of-month · month · day-of-week</MudText>
<MudSimpleTable Dense="true" Class="mb-2" Style="font-size:0.8125rem;">
    <thead><tr><th>Expression</th><th>Meaning</th></tr></thead>
    <tbody>
        <tr><td><code>* * * * *</code></td><td>Every minute</td></tr>
        <tr><td><code>*/5 * * * *</code></td><td>Every 5 minutes</td></tr>
        <tr><td><code>0 * * * *</code></td><td>Every hour</td></tr>
        <tr><td><code>0 8 * * *</code></td><td>Daily at 8 am</td></tr>
        <tr><td><code>0 0 * * 0</code></td><td>Weekly on Sunday midnight</td></tr>
        <tr><td><code>0 0 1 * *</code></td><td>Monthly on the 1st</td></tr>
    </tbody>
</MudSimpleTable>

@if (!Compact)
{
    <MudText Typo="Typo.subtitle2" Class="mt-2 mb-1">Managing Jobs</MudText>
    <ul style="margin: 0 0 0.75rem; padding-left: 1.25rem; font-size: 0.875rem;">
        <li>Use the <strong>toggle switch</strong> in the table to enable or disable a job without deleting it.</li>
        <li><strong>Run Now</strong> fires the job immediately, independent of its schedule.</li>
        <li><strong>Last Result</strong> shows the exit code from the most recent scheduled run.</li>
    </ul>

    <MudText Typo="Typo.subtitle2" Class="mt-2 mb-1">Tips</MudText>
    <ul style="margin: 0; padding-left: 1.25rem; font-size: 0.875rem;">
        <li>The scheduler checks for due jobs every 15 seconds — jobs may fire up to 15 s late.</li>
        <li>All scheduled runs appear in <MudLink Href="/history">Execution History</MudLink> like any manual run.</li>
        <li>Use <code>*/n</code> for "every nth" unit, e.g. <code>*/15 * * * *</code> = every 15 minutes.</li>
    </ul>
}

@code {
    [Parameter] public bool Compact { get; set; }
}
