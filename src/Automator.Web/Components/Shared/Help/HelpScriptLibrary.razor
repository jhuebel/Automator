<MudText Typo="Typo.h6" Class="mb-1">Script Library</MudText>
@if (!Compact)
{
    <MudText Typo="Typo.body2" Class="mb-3" Color="Color.Secondary">
        The central store for all your automation scripts. Scripts are saved in the database and persist across restarts.
        Supported languages: <strong>Bash</strong>, <strong>PowerShell</strong>, <strong>Python</strong>, and <strong>Ansible Playbook</strong>.
    </MudText>
}

<MudText Typo="Typo.subtitle2" Class="mt-2 mb-1">Permissions</MudText>
<MudSimpleTable Dense="true" Class="mb-2" Style="font-size:0.8125rem;">
    <thead><tr><th>Role</th><th>View</th><th>Run</th><th>Create / Edit / Delete</th></tr></thead>
    <tbody>
        <tr><td>Viewer</td><td>✓</td><td>—</td><td>—</td></tr>
        <tr><td>Operator</td><td>✓</td><td>✓</td><td>—</td></tr>
        <tr><td>Developer</td><td>✓</td><td>✓</td><td>✓</td></tr>
        <tr><td>Admin</td><td>✓</td><td>✓</td><td>✓</td></tr>
    </tbody>
</MudSimpleTable>

<MudText Typo="Typo.subtitle2" Class="mt-2 mb-1">Finding Scripts</MudText>
<ul style="margin: 0 0 0.75rem; padding-left: 1.25rem; font-size: 0.875rem;">
    <li>Use the <strong>search box</strong> to filter by name, description, or tag.</li>
    <li>Use the <strong>language dropdown</strong> to show only scripts in one language.</li>
    <li>Click <strong>View source</strong> on any script card to see the code with syntax highlighting.</li>
</ul>

<AuthorizeView Roles="Admin,Developer">
    <MudText Typo="Typo.subtitle2" Class="mt-2 mb-1">Creating &amp; Editing Scripts</MudText>
    <ol style="margin: 0 0 0.75rem; padding-left: 1.25rem; font-size: 0.875rem;">
        <li>Click <strong>New Script</strong> to open the editor.</li>
        <li>Enter a name, select the language, and optionally add comma-separated tags.</li>
        <li>Write or paste your script into the syntax-highlighted editor.</li>
        <li>Click <strong>Save</strong> to store it, or <strong>Cancel</strong> to discard changes.</li>
    </ol>

    @if (!Compact)
    {
        <MudText Typo="Typo.subtitle2" Class="mt-2 mb-1">AI Assistant</MudText>
        <MudText Typo="Typo.body2" Class="mb-1">
            When an Anthropic API key is configured in <MudLink Href="/settings?tab=ai">Settings → AI Assistant</MudLink>,
            an <strong>AI Assistant</strong> panel appears below the editor with three modes:
        </MudText>
        <ul style="margin: 0; padding-left: 1.25rem; font-size: 0.875rem;">
            <li><strong>Generate</strong> — describe a task in plain English; Claude writes the script</li>
            <li><strong>Improve</strong> — give instructions; Claude rewrites the current script</li>
            <li><strong>Explain</strong> — Claude describes in plain language what the script does</li>
        </ul>
    }
</AuthorizeView>

@if (!Compact)
{
    <MudText Typo="Typo.subtitle2" Class="mt-3 mb-1">Tips</MudText>
    <ul style="margin: 0; padding-left: 1.25rem; font-size: 0.875rem;">
        <li>Tags are comma-separated (e.g. <code>backup, cron, linux</code>) and used for filtering.</li>
        <li>The editor supports full syntax highlighting for all four languages.</li>
        <li>Changing the language dropdown updates highlighting immediately.</li>
    </ul>
}

@code {
    [Parameter] public bool Compact { get; set; }
}
