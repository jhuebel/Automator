<MudText Typo="Typo.h6" Class="mb-1">Run Script</MudText>
@if (!Compact)
{
    <MudText Typo="Typo.body2" Class="mb-3" Color="Color.Secondary">
        Execute any script on demand and watch its output stream in real time.
        Available to <strong>Admins</strong>, <strong>Developers</strong>, and <strong>Operators</strong>.
    </MudText>
}

<MudText Typo="Typo.subtitle2" Class="mt-2 mb-1">How to Run a Script</MudText>
<ol style="margin: 0 0 0.75rem; padding-left: 1.25rem; font-size: 0.875rem;">
    <li>Select a script from the list on the left (or navigate from the Script Library's <strong>Run</strong> button).</li>
    <li>Click <strong>Run</strong> — output begins streaming immediately.</li>
    <li>Click <strong>Cancel</strong> at any time to stop the script mid-execution.</li>
    <li>Use <strong>Clear</strong> to wipe the terminal without affecting history.</li>
</ol>

<MudText Typo="Typo.subtitle2" Class="mt-2 mb-1">Reading Output</MudText>
<ul style="margin: 0 0 0.75rem; padding-left: 1.25rem; font-size: 0.875rem;">
    <li>Standard output appears in the terminal in white.</li>
    <li>Standard error lines are highlighted in <span style="color:#f48771;">orange/red</span>.</li>
    <li>The <strong>exit code</strong> is shown after the script finishes. <code>0</code> = success; any other value = error.</li>
    <li>Execution time is displayed as wall-clock duration.</li>
</ul>

@if (!Compact)
{
    <MudText Typo="Typo.subtitle2" Class="mt-2 mb-1">Terraform Scripts</MudText>
    <MudText Typo="Typo.body2" Class="mb-1">
        Terraform scripts run in two phases — <code>terraform init</code> then <code>terraform apply -auto-approve</code> — both streamed to the output panel.
        Each run uses a fresh temporary directory; state is ephemeral unless you configure a remote backend in your HCL.
        Variables are injected as <code>TF_VAR_&lt;name&gt;</code> environment variables and accessed as <code>var.&lt;name&gt;</code> inside your configuration.
    </MudText>

    <MudText Typo="Typo.subtitle2" Class="mt-2 mb-1">Tips</MudText>
    <ul style="margin: 0; padding-left: 1.25rem; font-size: 0.875rem;">
        <li>Every run is automatically saved to <MudLink Href="/history">Execution History</MudLink> regardless of outcome.</li>
        <li>Scripts run under the same OS user account as the Automator process.</li>
        <li>Long-running scripts will be cancelled automatically if they exceed the timeout configured in <MudLink Href="/settings">Settings</MudLink>.</li>
    </ul>
}

@code {
    [Parameter] public bool Compact { get; set; }
}
