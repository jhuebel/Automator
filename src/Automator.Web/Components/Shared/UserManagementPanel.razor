@inject UserManager<ApplicationUser> UserManager
@inject RoleManager<IdentityRole> RoleManager
@inject IAuditLogService AuditService
@inject IConfiguration Configuration

<PageHelp>
    <strong>Role access levels:</strong>
    <ul class="mb-0 mt-1 ps-3">
        <li><strong>Admin</strong> — full access: manage users, create/edit/delete scripts, manage jobs, and run scripts</li>
        <li><strong>Operator</strong> — run scripts and manage scheduled jobs; cannot edit scripts or manage users</li>
        <li><strong>Viewer</strong> — read-only: browse scripts, view history, and check system status</li>
    </ul>
    You cannot change your own role or delete your own account. The protected admin account cannot be deleted or have its username or role changed.
</PageHelp>

<div class="d-flex justify-content-end mb-3">
    <button class="btn btn-primary" @onclick="() => { IsAdding = true; ClearAddForm(); }">
        <i class="bi bi-person-plus-fill me-1"></i>Add User
    </button>
</div>

@if (IsAdding)
{
    <div class="card mb-4 border-primary">
        <div class="card-header bg-primary text-white fw-semibold">New User</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Username</label>
                    <input class="form-control" @bind="NewUsername" placeholder="username" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Email</label>
                    <input class="form-control" @bind="NewEmail" placeholder="user@example.com" type="email" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Password</label>
                    <input class="form-control" @bind="NewPassword" type="password" placeholder="Min 8 characters" />
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-semibold">Role</label>
                    <select class="form-select" @bind="NewRole">
                        @foreach (var role in AvailableRoles)
                        {
                            <option value="@role">@role</option>
                        }
                    </select>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(AddError))
            {
                <div class="alert alert-danger py-2 mt-3 small">@AddError</div>
            }
            <div class="d-flex gap-2 mt-3">
                <button class="btn btn-primary" @onclick="CreateUserAsync">
                    <i class="bi bi-person-check me-1"></i>Create
                </button>
                <button class="btn btn-outline-secondary" @onclick="() => IsAdding = false">Cancel</button>
            </div>
        </div>
    </div>
}

@if (UserList is null)
{
    <div class="d-flex align-items-center gap-2 text-muted">
        <span class="spinner-border spinner-border-sm"></span> Loading users...
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Username</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Lockout</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in UserList)
                {
                    var isProtected = user.UserName == ProtectedUsername;
                    var isSelf = user.Id == CurrentUserId;
                    <tr>
                        <td class="fw-semibold">
                            @user.UserName
                            @if (isSelf)
                            {
                                <span class="badge bg-secondary ms-1">you</span>
                            }
                            @if (isProtected)
                            {
                                <span class="badge bg-danger ms-1">protected</span>
                            }
                        </td>
                        <td class="text-muted small">@user.Email</td>
                        <td>
                            @foreach (var role in user.Roles)
                            {
                                <span class="badge @RoleBadgeClass(role) me-1">@role</span>
                            }
                        </td>
                        <td>
                            @if (user.LockoutEnd.HasValue && user.LockoutEnd > DateTimeOffset.UtcNow)
                            {
                                <span class="badge bg-warning text-dark">Locked</span>
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex gap-1">
                                <button class="btn btn-sm btn-outline-primary"
                                        title="Edit user"
                                        @onclick="() => StartEdit(user)">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                @if (!isProtected && !isSelf)
                                {
                                    <button class="btn btn-sm btn-outline-danger"
                                            title="Delete user"
                                            @onclick="() => ConfirmDeleteUser(user)">
                                        <i class="bi bi-person-x"></i>
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="text-muted small">@UserList.Count user(s) total</div>
}

@if (EditingUser is not null)
{
    var editIsProtected = EditingUser.UserName == ProtectedUsername;
    var editIsSelf      = EditingUser.Id == CurrentUserId;
    var roleReadOnly    = editIsProtected || editIsSelf;
    <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-person-gear me-2"></i>Edit User</h5>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Username</label>
                        <input class="form-control" @bind="EditUsername" placeholder="username"
                               disabled="@editIsProtected" />
                        @if (editIsProtected)
                        {
                            <div class="form-text">Username cannot be changed for the protected admin account.</div>
                        }
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Email</label>
                        <input class="form-control" @bind="EditEmail" type="email" placeholder="user@example.com" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">New Password</label>
                        <input class="form-control" @bind="EditPassword" type="password" placeholder="Leave blank to keep existing" />
                        <div class="form-text">Min 8 characters. Leave blank to keep the current password.</div>
                    </div>
                    <div class="mb-0">
                        <label class="form-label fw-semibold">Role</label>
                        <select class="form-select" @bind="EditRole" disabled="@roleReadOnly">
                            @foreach (var role in AvailableRoles)
                            {
                                <option value="@role">@role</option>
                            }
                        </select>
                        @if (roleReadOnly)
                        {
                            <div class="form-text">
                                @(editIsProtected ? "Role cannot be changed for the protected admin account." : "You cannot change your own role.")
                            </div>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(EditError))
                    {
                        <div class="alert alert-danger py-2 mt-3 small mb-0">@EditError</div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-primary" @onclick="SaveEditAsync" disabled="@IsSavingEdit">
                        <i class="bi bi-floppy me-1"></i>Save
                    </button>
                    <button class="btn btn-secondary" @onclick="CancelEdit">Cancel</button>
                </div>
            </div>
        </div>
    </div>
}

@if (DeletingUser is not null)
{
    <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Delete</h5>
                </div>
                <div class="modal-body">
                    Delete user <strong>@DeletingUser.UserName</strong>? This cannot be undone.
                </div>
                <div class="modal-footer">
                    <button class="btn btn-danger" @onclick="DeleteUserConfirmedAsync">Delete</button>
                    <button class="btn btn-secondary" @onclick="() => DeletingUser = null">Cancel</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private string ProtectedUsername { get; set; } = "admin";

    private List<UserViewModel>? UserList { get; set; }
    private List<string> AvailableRoles { get; set; } = [];
    private string? CurrentUserId { get; set; }
    private string CurrentUsername { get; set; } = string.Empty;
    private UserViewModel? DeletingUser { get; set; }

    // Add form
    private bool IsAdding { get; set; }
    private string NewUsername { get; set; } = string.Empty;
    private string NewEmail { get; set; } = string.Empty;
    private string NewPassword { get; set; } = string.Empty;
    private string NewRole { get; set; } = "Viewer";
    private string AddError { get; set; } = string.Empty;

    // Edit modal
    private UserViewModel? EditingUser { get; set; }
    private string EditUsername { get; set; } = string.Empty;
    private string EditEmail { get; set; } = string.Empty;
    private string EditPassword { get; set; } = string.Empty;
    private string EditRole { get; set; } = string.Empty;
    private string EditError { get; set; } = string.Empty;
    private bool IsSavingEdit { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is not null)
        {
            var auth = await AuthState;
            CurrentUserId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            CurrentUsername = auth.User.Identity?.Name ?? string.Empty;
        }

        ProtectedUsername = Configuration["DefaultAdmin:Username"] ?? "admin";
        AvailableRoles = RoleManager.Roles.Select(r => r.Name!).OrderBy(r => r).ToList();
        await LoadUsersAsync();
    }

    private async Task LoadUsersAsync()
    {
        var list = new List<UserViewModel>();
        foreach (var user in UserManager.Users.ToList())
        {
            var roles = await UserManager.GetRolesAsync(user);
            list.Add(new UserViewModel(user.Id, user.UserName!, user.Email!, [.. roles], user.LockoutEnd));
        }
        UserList = [.. list.OrderBy(u => u.UserName)];
    }

    private async Task CreateUserAsync()
    {
        AddError = string.Empty;
        if (string.IsNullOrWhiteSpace(NewUsername) || string.IsNullOrWhiteSpace(NewPassword))
        {
            AddError = "Username and password are required.";
            return;
        }

        var user = new ApplicationUser
        {
            UserName = NewUsername.Trim(),
            Email = NewEmail.Trim(),
            EmailConfirmed = true
        };

        var result = await UserManager.CreateAsync(user, NewPassword);
        if (!result.Succeeded)
        {
            AddError = string.Join(" ", result.Errors.Select(e => e.Description));
            return;
        }

        await UserManager.AddToRoleAsync(user, NewRole);
        await AuditService.LogAsync("User.Created", NewUsername.Trim(), $"role: {NewRole}", CurrentUsername);
        IsAdding = false;
        await LoadUsersAsync();
    }

    private void StartEdit(UserViewModel user)
    {
        EditingUser = user;
        EditUsername = user.UserName;
        EditEmail = user.Email;
        EditPassword = string.Empty;
        EditRole = user.Roles.FirstOrDefault() ?? AvailableRoles.FirstOrDefault() ?? string.Empty;
        EditError = string.Empty;
        IsSavingEdit = false;
    }

    private void CancelEdit()
    {
        EditingUser = null;
        EditError = string.Empty;
    }

    private async Task SaveEditAsync()
    {
        if (EditingUser is null) return;
        EditError = string.Empty;

        if (string.IsNullOrWhiteSpace(EditUsername))
        {
            EditError = "Username is required.";
            return;
        }

        IsSavingEdit = true;
        try
        {
            var appUser = await UserManager.FindByIdAsync(EditingUser.Id);
            if (appUser is null) { EditError = "User not found."; return; }

            bool isProtected = EditingUser.UserName == ProtectedUsername;
            bool isSelf = EditingUser.Id == CurrentUserId;
            var changes = new List<string>();

            // Username (blocked for protected account)
            if (!isProtected && appUser.UserName != EditUsername.Trim())
            {
                var r = await UserManager.SetUserNameAsync(appUser, EditUsername.Trim());
                if (!r.Succeeded) { EditError = string.Join(" ", r.Errors.Select(e => e.Description)); return; }
                changes.Add($"username: {EditingUser.UserName} → {EditUsername.Trim()}");
            }

            // Email
            var trimmedEmail = EditEmail.Trim();
            if (appUser.Email != trimmedEmail)
            {
                appUser.Email = trimmedEmail;
                appUser.NormalizedEmail = trimmedEmail.ToUpperInvariant();
                appUser.EmailConfirmed = true;
                var r = await UserManager.UpdateAsync(appUser);
                if (!r.Succeeded) { EditError = string.Join(" ", r.Errors.Select(e => e.Description)); return; }
                changes.Add("email updated");
            }

            // Password (optional)
            if (!string.IsNullOrWhiteSpace(EditPassword))
            {
                var token = await UserManager.GeneratePasswordResetTokenAsync(appUser);
                var r = await UserManager.ResetPasswordAsync(appUser, token, EditPassword);
                if (!r.Succeeded) { EditError = string.Join(" ", r.Errors.Select(e => e.Description)); return; }
                changes.Add("password reset");
            }

            // Role (blocked for protected account and self)
            if (!isProtected && !isSelf)
            {
                var currentRoles = await UserManager.GetRolesAsync(appUser);
                if (!currentRoles.Contains(EditRole))
                {
                    await UserManager.RemoveFromRolesAsync(appUser, currentRoles);
                    await UserManager.AddToRoleAsync(appUser, EditRole);
                    changes.Add($"role: {string.Join(",", currentRoles)} → {EditRole}");
                }
            }

            if (changes.Count > 0)
                await AuditService.LogAsync("User.Updated", EditingUser.UserName, string.Join("; ", changes), CurrentUsername);

            EditingUser = null;
            await LoadUsersAsync();
        }
        finally
        {
            IsSavingEdit = false;
        }
    }

    private void ConfirmDeleteUser(UserViewModel user) => DeletingUser = user;

    private async Task DeleteUserConfirmedAsync()
    {
        if (DeletingUser is null) return;
        var user = await UserManager.FindByIdAsync(DeletingUser.Id);
        if (user is not null)
        {
            await UserManager.DeleteAsync(user);
            await AuditService.LogAsync("User.Deleted", DeletingUser.UserName, null, CurrentUsername);
        }
        DeletingUser = null;
        await LoadUsersAsync();
    }

    private void ClearAddForm()
    {
        NewUsername = NewEmail = NewPassword = AddError = string.Empty;
        NewRole = "Viewer";
    }

    private static string RoleBadgeClass(string role) => role switch
    {
        "Admin" => "bg-danger",
        "Operator" => "bg-primary",
        "Viewer" => "bg-secondary",
        _ => "bg-dark"
    };

    private record UserViewModel(string Id, string UserName, string Email, List<string> Roles, DateTimeOffset? LockoutEnd);
}
