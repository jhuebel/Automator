@inject UserManager<ApplicationUser> UserManager
@inject RoleManager<IdentityRole> RoleManager
@inject IAuditLogService AuditService
@inject IConfiguration Configuration

<PageHelp>
    <strong>Role access levels:</strong>
    <ul style="margin: 0.25rem 0 0; padding-left: 1.25rem;">
        <li><strong>Admin</strong> — full access: manage users, create/edit/delete scripts, manage jobs, and run scripts</li>
        <li><strong>Operator</strong> — run scripts and manage scheduled jobs; cannot edit scripts or manage users</li>
        <li><strong>Viewer</strong> — read-only: browse scripts, view history, and check system status</li>
    </ul>
    You cannot change your own role or delete your own account. The protected admin account cannot be deleted or have its username or role changed.
</PageHelp>

<div style="display: flex; justify-content: flex-end; margin-bottom: 1rem;">
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PersonAdd"
               OnClick="() => { IsAdding = true; ClearAddForm(); }">Add User</MudButton>
</div>

@if (IsAdding)
{
    <MudCard Class="mb-4" Elevation="2" Style="border-top: 4px solid var(--mud-palette-primary);">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">New User</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            <MudGrid Spacing="2">
                <MudItem xs="12" md="3">
                    <MudTextField @bind-Value="NewUsername" Label="Username" Variant="Variant.Outlined"
                                  Margin="Margin.Dense" Placeholder="username" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="NewEmail" Label="Email" Variant="Variant.Outlined"
                                  InputType="InputType.Email" Margin="Margin.Dense" Placeholder="user@example.com" />
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudTextField @bind-Value="NewPassword" Label="Password" Variant="Variant.Outlined"
                                  InputType="InputType.Password" Margin="Margin.Dense" Placeholder="Min 8 characters" />
                </MudItem>
                <MudItem xs="12" md="2">
                    <MudSelect T="string" @bind-Value="NewRole" Label="Role" Variant="Variant.Outlined"
                               Margin="Margin.Dense">
                        @foreach (var role in AvailableRoles)
                        {
                            <MudSelectItem T="string" Value="@role">@role</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            </MudGrid>
            @if (!string.IsNullOrEmpty(AddError))
            {
                <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2">@AddError</MudAlert>
            }
        </MudCardContent>
        <MudCardActions>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PersonAdd"
                       OnClick="CreateUserAsync">Create</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="() => IsAdding = false">Cancel</MudButton>
        </MudCardActions>
    </MudCard>
}

@if (EditingUser is not null)
{
    var editIsProtected = EditingUser.UserName == ProtectedUsername;
    var editIsSelf      = EditingUser.Id == CurrentUserId;
    var roleReadOnly    = editIsProtected || editIsSelf;

    <MudCard Class="mb-4" Elevation="2" Style="border-top: 4px solid var(--mud-palette-warning);">
        <MudCardHeader>
            <CardHeaderContent>
                <div style="display: flex; align-items: center; gap: 0.5rem;">
                    <MudIcon Icon="@Icons.Material.Filled.ManageAccounts" />
                    <MudText Typo="Typo.h6">Edit User: @EditingUser.UserName</MudText>
                </div>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            <MudGrid Spacing="2">
                <MudItem xs="12" md="3">
                    <MudTextField @bind-Value="EditUsername" Label="Username" Variant="Variant.Outlined"
                                  Margin="Margin.Dense" Disabled="@editIsProtected"
                                  HelperText="@(editIsProtected ? "Cannot change for protected admin." : null)" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="EditEmail" Label="Email" Variant="Variant.Outlined"
                                  InputType="InputType.Email" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudTextField @bind-Value="EditPassword" Label="New Password" Variant="Variant.Outlined"
                                  InputType="InputType.Password" Margin="Margin.Dense"
                                  Placeholder="Leave blank to keep existing"
                                  HelperText="Min 8 characters. Leave blank to keep current." />
                </MudItem>
                <MudItem xs="12" md="2">
                    <MudSelect T="string" @bind-Value="EditRole" Label="Role" Variant="Variant.Outlined"
                               Margin="Margin.Dense" Disabled="@roleReadOnly"
                               HelperText="@(roleReadOnly ? (editIsProtected ? "Cannot change for protected admin." : "Cannot change your own role.") : null)">
                        @foreach (var role in AvailableRoles)
                        {
                            <MudSelectItem T="string" Value="@role">@role</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            </MudGrid>
            @if (!string.IsNullOrEmpty(EditError))
            {
                <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2">@EditError</MudAlert>
            }
        </MudCardContent>
        <MudCardActions>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save"
                       OnClick="SaveEditAsync" Disabled="@IsSavingEdit">Save</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="CancelEdit">Cancel</MudButton>
        </MudCardActions>
    </MudCard>
}

@if (UserList is null)
{
    <div style="display: flex; align-items: center; gap: 0.5rem;">
        <MudProgressCircular Size="Size.Small" Indeterminate="true" />
        <MudText Color="Color.Secondary">Loading users...</MudText>
    </div>
}
else
{
    <MudPaper Elevation="1" Class="overflow-auto">
        <MudSimpleTable Hover="true" Dense="true">
            <thead>
                <tr>
                    <th>Username</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Lockout</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in UserList)
                {
                    var isProtected = user.UserName == ProtectedUsername;
                    var isSelf = user.Id == CurrentUserId;
                    <tr>
                        <td>
                            <div style="display: flex; align-items: center; gap: 0.25rem; flex-wrap: wrap;">
                                <span style="font-weight: 600;">@user.UserName</span>
                                @if (isSelf)
                                {
                                    <MudChip T="string" Color="Color.Default" Size="Size.Small">you</MudChip>
                                }
                                @if (isProtected)
                                {
                                    <MudChip T="string" Color="Color.Error" Size="Size.Small">protected</MudChip>
                                }
                            </div>
                        </td>
                        <td style="font-size: 0.875rem; color: var(--mud-palette-text-secondary);">@user.Email</td>
                        <td>
                            @foreach (var role in user.Roles)
                            {
                                <MudChip T="string" Color="@RoleColor(role)" Size="Size.Small">@role</MudChip>
                            }
                        </td>
                        <td>
                            @if (user.LockoutEnd.HasValue && user.LockoutEnd > DateTimeOffset.UtcNow)
                            {
                                <MudChip T="string" Color="Color.Warning" Size="Size.Small">Locked</MudChip>
                            }
                        </td>
                        <td>
                            <div style="display: flex; gap: 0.125rem;">
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small"
                                               OnClick="() => StartEdit(user)" />
                                @if (!isProtected && !isSelf)
                                {
                                    <MudIconButton Icon="@Icons.Material.Filled.PersonRemove" Color="Color.Error" Size="Size.Small"
                                                   OnClick="() => ConfirmDeleteUser(user)" />
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    </MudPaper>
    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">@UserList.Count user(s) total</MudText>
}

@if (DeletingUser is not null)
{
    <div style="position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 1000; display: flex; align-items: center; justify-content: center;">
        <MudCard Style="width: 380px;">
            <MudCardHeader>
                <CardHeaderContent><MudText Typo="Typo.h6">Confirm Delete</MudText></CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                Delete user <strong>@DeletingUser.UserName</strong>? This cannot be undone.
            </MudCardContent>
            <MudCardActions>
                <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="DeleteConfirmedAsync">Delete</MudButton>
                <MudButton Variant="Variant.Outlined" OnClick="() => DeletingUser = null">Cancel</MudButton>
            </MudCardActions>
        </MudCard>
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private string ProtectedUsername { get; set; } = "admin";

    private List<UserViewModel>? UserList { get; set; }
    private List<string> AvailableRoles { get; set; } = [];
    private string? CurrentUserId { get; set; }
    private string CurrentUsername { get; set; } = string.Empty;

    // Add form
    private bool IsAdding { get; set; }
    private string NewUsername { get; set; } = string.Empty;
    private string NewEmail { get; set; } = string.Empty;
    private string NewPassword { get; set; } = string.Empty;
    private string NewRole { get; set; } = "Viewer";
    private string AddError { get; set; } = string.Empty;

    // Delete confirmation
    private UserViewModel? DeletingUser { get; set; }

    // Edit panel
    private UserViewModel? EditingUser { get; set; }
    private string EditUsername { get; set; } = string.Empty;
    private string EditEmail { get; set; } = string.Empty;
    private string EditPassword { get; set; } = string.Empty;
    private string EditRole { get; set; } = string.Empty;
    private string EditError { get; set; } = string.Empty;
    private bool IsSavingEdit { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is not null)
        {
            var auth = await AuthState;
            CurrentUserId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            CurrentUsername = auth.User.Identity?.Name ?? string.Empty;
        }

        ProtectedUsername = Configuration["DefaultAdmin:Username"] ?? "admin";
        AvailableRoles = RoleManager.Roles.Select(r => r.Name!).OrderBy(r => r).ToList();
        await LoadUsersAsync();
    }

    private async Task LoadUsersAsync()
    {
        var list = new List<UserViewModel>();
        foreach (var user in UserManager.Users.ToList())
        {
            var roles = await UserManager.GetRolesAsync(user);
            list.Add(new UserViewModel(user.Id, user.UserName!, user.Email!, [.. roles], user.LockoutEnd));
        }
        UserList = [.. list.OrderBy(u => u.UserName)];
    }

    private async Task CreateUserAsync()
    {
        AddError = string.Empty;
        if (string.IsNullOrWhiteSpace(NewUsername) || string.IsNullOrWhiteSpace(NewPassword))
        {
            AddError = "Username and password are required.";
            return;
        }

        var user = new ApplicationUser
        {
            UserName = NewUsername.Trim(),
            Email = NewEmail.Trim(),
            EmailConfirmed = true
        };

        var result = await UserManager.CreateAsync(user, NewPassword);
        if (!result.Succeeded)
        {
            AddError = string.Join(" ", result.Errors.Select(e => e.Description));
            return;
        }

        await UserManager.AddToRoleAsync(user, NewRole);
        await AuditService.LogAsync("User.Created", NewUsername.Trim(), $"role: {NewRole}", CurrentUsername);
        IsAdding = false;
        await LoadUsersAsync();
    }

    private void StartEdit(UserViewModel user)
    {
        EditingUser = user;
        EditUsername = user.UserName;
        EditEmail = user.Email;
        EditPassword = string.Empty;
        EditRole = user.Roles.FirstOrDefault() ?? AvailableRoles.FirstOrDefault() ?? string.Empty;
        EditError = string.Empty;
        IsSavingEdit = false;
        IsAdding = false;
    }

    private void CancelEdit()
    {
        EditingUser = null;
        EditError = string.Empty;
    }

    private async Task SaveEditAsync()
    {
        if (EditingUser is null) return;
        EditError = string.Empty;

        if (string.IsNullOrWhiteSpace(EditUsername))
        {
            EditError = "Username is required.";
            return;
        }

        IsSavingEdit = true;
        try
        {
            var appUser = await UserManager.FindByIdAsync(EditingUser.Id);
            if (appUser is null) { EditError = "User not found."; return; }

            bool isProtected = EditingUser.UserName == ProtectedUsername;
            bool isSelf = EditingUser.Id == CurrentUserId;
            var changes = new List<string>();

            if (!isProtected && appUser.UserName != EditUsername.Trim())
            {
                var r = await UserManager.SetUserNameAsync(appUser, EditUsername.Trim());
                if (!r.Succeeded) { EditError = string.Join(" ", r.Errors.Select(e => e.Description)); return; }
                changes.Add($"username: {EditingUser.UserName} → {EditUsername.Trim()}");
            }

            var trimmedEmail = EditEmail.Trim();
            if (appUser.Email != trimmedEmail)
            {
                appUser.Email = trimmedEmail;
                appUser.NormalizedEmail = trimmedEmail.ToUpperInvariant();
                appUser.EmailConfirmed = true;
                var r = await UserManager.UpdateAsync(appUser);
                if (!r.Succeeded) { EditError = string.Join(" ", r.Errors.Select(e => e.Description)); return; }
                changes.Add("email updated");
            }

            if (!string.IsNullOrWhiteSpace(EditPassword))
            {
                var token = await UserManager.GeneratePasswordResetTokenAsync(appUser);
                var r = await UserManager.ResetPasswordAsync(appUser, token, EditPassword);
                if (!r.Succeeded) { EditError = string.Join(" ", r.Errors.Select(e => e.Description)); return; }
                changes.Add("password reset");
            }

            if (!isProtected && !isSelf)
            {
                var currentRoles = await UserManager.GetRolesAsync(appUser);
                if (!currentRoles.Contains(EditRole))
                {
                    await UserManager.RemoveFromRolesAsync(appUser, currentRoles);
                    await UserManager.AddToRoleAsync(appUser, EditRole);
                    changes.Add($"role: {string.Join(",", currentRoles)} → {EditRole}");
                }
            }

            if (changes.Count > 0)
                await AuditService.LogAsync("User.Updated", EditingUser.UserName, string.Join("; ", changes), CurrentUsername);

            EditingUser = null;
            await LoadUsersAsync();
        }
        finally
        {
            IsSavingEdit = false;
        }
    }

    private void ConfirmDeleteUser(UserViewModel user) => DeletingUser = user;

    private async Task DeleteConfirmedAsync()
    {
        if (DeletingUser is null) return;
        var user = await UserManager.FindByIdAsync(DeletingUser.Id);
        if (user is not null)
        {
            await UserManager.DeleteAsync(user);
            await AuditService.LogAsync("User.Deleted", DeletingUser.UserName, null, CurrentUsername);
        }
        DeletingUser = null;
        await LoadUsersAsync();
    }

    private void ClearAddForm()
    {
        NewUsername = NewEmail = NewPassword = AddError = string.Empty;
        NewRole = "Viewer";
    }

    private static Color RoleColor(string role) => role switch
    {
        "Admin"     => Color.Error,
        "Developer" => Color.Tertiary,
        "Operator"  => Color.Primary,
        "Viewer"    => Color.Default,
        _           => Color.Dark
    };

    private record UserViewModel(string Id, string UserName, string Email, List<string> Roles, DateTimeOffset? LockoutEnd);
}
