[Unit]
Description=Automator queue worker %i
After=network.target

[Service]
Type=simple
User=automator
Group=automator
WorkingDirectory=/opt/automator/app
ExecStart=/usr/bin/php /opt/automator/app/artisan queue:work --queue=executions,default --tries=1 --timeout=310 --sleep=1
Restart=always
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/opt/automator/app/storage /opt/automator/data

[Install]
WantedBy=multi-user.target
